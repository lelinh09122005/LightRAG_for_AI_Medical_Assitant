    </node>
    <node id="Decreased Concentration and Memory">
      <data key="d0">Decreased Concentration and Memory</data>
      <data key="d1">symptom</data>
      <data key="d2">Impaired concentration and memory are potential consequences of Vitamin B12 deficiency.</data>
      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231949</data>
      <data key="d6" />
    </node>
    <node id="Irritability and Depression">
      <data key="d0">Irritability and Depression</data>
      <data key="d1">symptom</data>
      <data key="d2">Irritability, depression, and mood disturbances can be symptoms of Vitamin B12 deficiency.</data>
      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231949</data>
