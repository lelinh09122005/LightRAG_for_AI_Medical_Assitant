      <data key="d11">unknown_source</data>
      <data key="d12">1776226358</data>
      <data key="d13" />
    </edge>
    <edge source="Peripheral Neuropathy" target="HMSN (Hereditary Motor Sensory Neuropathy)">
      <data key="d7">1.0</data>
      <data key="d8">Peripheral neuropathy can be caused or exacerbated by primary vasculitides.</data>
