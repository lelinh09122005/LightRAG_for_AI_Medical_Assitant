    </node>
    <node id="Fechtner Syndrome">
      <data key="d0">Fechtner Syndrome</data>
      <data key="d1">condition</data>
      <data key="d2">Fechtner syndrome is a rare genetic disorder affecting primarily males, characterized by thrombocytopenia (low platelet count), giant platelets, and intellectual disability due to mutations in the GNB3 gene.</data>
      <data key="d3">chunk-e349119c3189688316f142a76b2f2e86</data>
      <data key="d4">unknown_source</data>
