    <node id="Pleural Effusion">
      <data key="d0">Pleural Effusion</data>
      <data key="d1">concept</data>
      <data key="d2">Pleural effusion is a medical condition involving fluid accumulation in the pleural space.</data>
      <data key="d3">chunk-c16a4c902adb4dbeda6878a55d31bfe9</data>
      <data key="d4">unknown_source</data>
