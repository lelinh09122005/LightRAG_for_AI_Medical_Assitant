    <node id="Sarcoplasmic Reticulum">
      <data key="d0">Sarcoplasmic Reticulum</data>
      <data key="d1">location</data>
      <data key="d2">The sarcoplasmic reticulum is a critical component in the regulation of calcium ion flux in cardiac myocytes.</data>
      <data key="d3">chunk-b8f8e8de9e94ff3a0fb159812013b14d</data>
      <data key="d4">unknown_source</data>
