    <node id="Chagas Disease">
      <data key="d0">Chagas Disease</data>
      <data key="d1">disease</data>
      <data key="d2">Chagas disease is a serious and potentially life-threatening tropical parasitic infection caused by the parasite Trypanosoma cruzi.</data>
      <data key="d3">chunk-42e608f979ae406dce55ee3db11f5b0e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776225962</data>
