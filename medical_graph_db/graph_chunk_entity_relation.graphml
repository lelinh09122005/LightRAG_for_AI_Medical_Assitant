    </edge>
    <edge source="Pylephlebitis" target="Appendicitis">
      <data key="d7">1.0</data>
      <data key="d8">Similar to diverticulitis, pylephlebitis can arise from appendicitis as an infectious process.</data>
      <data key="d9">association,complication</data>
      <data key="d10">chunk-c62e0e5e965a5609d60ac725c7a40a57</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776199282</data>
