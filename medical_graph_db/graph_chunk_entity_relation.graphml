    </node>
    <node id="Intrathecal Chemotherapy">
      <data key="d0">Intrathecal Chemotherapy</data>
      <data key="d1">treatment</data>
      <data key="d2">Intrathecal chemotherapy is the mainstay of therapy for neoplastic meningitis.</data>
      <data key="d3">chunk-b5c6f77b16e16e44d387190c97da1df2</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776211798</data>
      <data key="d6" />
    </node>
    <node id="Meninges">
      <data key="d0">Meninges</data>
      <data key="d1">naturalobject</data>
      <data key="d2">The meninges are protective membranes covering the central nervous system.&lt;SEP&gt;The meninges are protective layers of tissue covering the central nervous system.</data>
      <data key="d3">chunk-b5c6f77b16e16e44d387190c97da1df2&lt;SEP&gt;chunk-2f9f6e0c1ac72f2d9f132ba1b3ab8be3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776221684</data>
