    <node id="Type 1 Diabetes Mellitus">
      <data key="d0">Type 1 Diabetes Mellitus</data>
      <data key="d1">disease</data>
      <data key="d2">Type 1 diabetes mellitus is a condition that affects an individual's ability to regulate blood sugar levels.</data>
      <data key="d3">chunk-306239ff844288e7df13b6ff43d0432b</data>
      <data key="d4">unknown_source</data>
