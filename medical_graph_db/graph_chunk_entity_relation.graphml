      <data key="d0">IBD</data>
      <data key="d3">chunk-491c0761387cab9f81178653066edcbc</data>
      <data key="d2">Patients with inflammatory bowel disease are at an increased risk of developing colorectal cancer.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776204357</data>
      <data key="d6" />
    </node>
    <node id="IBD Patient">
      <data key="d0">IBD Patient</data>
      <data key="d3">chunk-491c0761387cab9f81178653066edcbc</data>
      <data key="d2">While patients with IBD have an increased risk of developing colorectal cancer, it is often diagnosed earlier than in the general population through routine surveillance.</data>
