    <node id="Endometrial Ablation">
      <data key="d0">Endometrial Ablation</data>
      <data key="d1">method</data>
      <data key="d2">Endometrial ablation is a medical procedure that removes or destroys the endometrial lining of a woman's uterus.</data>
      <data key="d3">chunk-40324022a0e3a72859b0d0b0a9c2b089</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217032</data>
      <data key="d6" />
    </node>
    <node id="Uterus">
      <data key="d0">Uterus</data>
      <data key="d1">location</data>
      <data key="d2">The uterus is the organ where endometrial ablation is performed.&lt;SEP&gt;The uterus is where leiomyomas typically develop and grow.&lt;SEP&gt;The uterus is a vital organ that plays a crucial role in female reproductive health.&lt;SEP&gt;The uterus (womb) is a female reproductive organ that supports fetal development during pregnancy.</data>
      <data key="d3">chunk-40324022a0e3a72859b0d0b0a9c2b089&lt;SEP&gt;chunk-c490a0037395bb80db5d9a147d89a6fd&lt;SEP&gt;chunk-9726252f8d24a278bed590bba4e8f9bf&lt;SEP&gt;chunk-b74be085e56dc55429b21339be974dcb</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776247667</data>
      <data key="d6" />
    </node>
    <node id="Hysterectomy">
      <data key="d0">Hysterectomy</data>
      <data key="d1">medicalprocedure</data>
      <data key="d2">Hysterectomy is an alternative surgical option for women who experience excessive bleeding, but may not be suitable for everyone.</data>
      <data key="d3">chunk-40324022a0e3a72859b0d0b0a9c2b089</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217032</data>
      <data key="d6" />
    </node>
    <node id="Excessive Bleeding">
      <data key="d0">Excessive Bleeding</data>
      <data key="d1">symptom</data>
      <data key="d2">Excessive bleeding during the menstrual cycle is a common reason for endometrial ablation.</data>
      <data key="d3">chunk-40324022a0e3a72859b0d0b0a9c2b089</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217032</data>
      <data key="d6" />
    </node>
    <node id="Menstrual Cycle">
      <data key="d0">Menstrual Cycle</data>
      <data key="d1">event</data>
      <data key="d2">The menstrual cycle is the natural process of a woman's body preparing for pregnancy, which can be affected by excessive bleeding.</data>
      <data key="d3">chunk-40324022a0e3a72859b0d0b0a9c2b089</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217032</data>
      <data key="d6" />
    </node>
    <node id="Endometrial Hyperplasia">
      <data key="d0">Endometrial Hyperplasia</data>
      <data key="d1">condition</data>
      <data key="d2">Endometrial hyperplasia is a condition where the uterine lining grows too thick, increasing the risk of cancer.</data>
      <data key="d3">chunk-40324022a0e3a72859b0d0b0a9c2b089</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217032</data>
      <data key="d6" />
    </node>
    <node id="Heparin">
      <data key="d0">Heparin</data>
      <data key="d3">chunk-40324022a0e3a72859b0d0b0a9c2b089</data>
      <data key="d2">Thrombocytopenia increases the risk of bleeding complications when taking heparin or other anticoagulant medications.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217034</data>
      <data key="d6" />
    </node>
    <node id="American Academy of Pediatrics">
      <data key="d0">American Academy of Pediatrics</data>
      <data key="d1">organization</data>
      <data key="d2">The American Academy of Pediatrics is an organization that provides guidelines and recommendations for medical practices.</data>
      <data key="d3">chunk-3cabd69644d8352c70635652f93fbfbb</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217255</data>
      <data key="d6" />
    </node>
    <node id="Blood Typing">
      <data key="d0">Blood Typing</data>
      <data key="d1">clinicalprocedure</data>
      <data key="d2">Blood typing is a clinical procedure used to determine an individual's blood type, which may be relevant during jaundice screening.</data>
      <data key="d3">chunk-3cabd69644d8352c70635652f93fbfbb</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217255</data>
      <data key="d6" />
    </node>
    <node id="Information">
      <data key="d0">Information</data>
      <data key="d1">content</data>
      <data key="d2">Providing information to parents about jaundice and its consequences is recommended by the American Academy of Pediatrics.</data>
      <data key="d3">chunk-3cabd69644d8352c70635652f93fbfbb</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217255</data>
      <data key="d6" />
    </node>
    <node id="G6PD Enzyme">
      <data key="d0">G6PD Enzyme</data>
      <data key="d3">chunk-3cabd69644d8352c70635652f93fbfbb</data>
      <data key="d2">The G6PD enzyme is involved in glucose-6-phosphate dehydrogenase metabolism, which may be linked to blood typing results.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217256</data>
      <data key="d6" />
    </node>
    <node id="Short Stature">
      <data key="d0">Short Stature</data>
      <data key="d1">symptom</data>
      <data key="d2">Short stature is a condition characterized by abnormally low height for an individual's age, sex, and genetics.&lt;SEP&gt;Individuals with HME typically have a short stature due to shortening and bowing of affected bones.</data>
      <data key="d3">chunk-865f279e1b6a3e8bf38bf34c9c655cb3&lt;SEP&gt;chunk-2cda899614de86249768a124b9366502</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241154</data>
      <data key="d6" />
    </node>
    <node id="Systemic Disorders">
      <data key="d0">Systemic Disorders</data>
      <data key="d1">cause</data>
      <data key="d2">Multiple systemic disorders are among the causes of short stature.</data>
      <data key="d3">chunk-865f279e1b6a3e8bf38bf34c9c655cb3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217330</data>
      <data key="d6" />
    </node>
    <node id="Endocrine Disorder">
      <data key="d0">Endocrine Disorder</data>
      <data key="d1">cause</data>
      <data key="d2">Short stature can be caused by endocrine disorders affecting growth hormone production.</data>
      <data key="d3">chunk-865f279e1b6a3e8bf38bf34c9c655cb3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217330</data>
      <data key="d6" />
    </node>
    <node id="Genetic Disorder">
      <data key="d0">Genetic Disorder</data>
      <data key="d1">data</data>
      <data key="d2">Genetic factors also contribute to the development of short stature.&lt;SEP&gt;A condition resulting from inherited mutations affecting gene function or expression.&lt;SEP&gt;Genetic disorders like Hemophilia C are relatively rare.</data>
      <data key="d3">chunk-865f279e1b6a3e8bf38bf34c9c655cb3&lt;SEP&gt;chunk-6711b1d821dab365387b1363037450c9&lt;SEP&gt;chunk-890ed5532260e84d43d5d4c567c6ab45</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776248715</data>
      <data key="d6" />
    </node>
    <node id="Skeletal Dysplasia">
      <data key="d0">Skeletal Dysplasia</data>
      <data key="d1">cause</data>
      <data key="d2">Skeletal dysplasias are a type of short stature caused by abnormalities in bone growth.</data>
      <data key="d3">chunk-865f279e1b6a3e8bf38bf34c9c655cb3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217330</data>
      <data key="d6" />
    </node>
    <node id="Growth Plate Abnormalities">
      <data key="d0">Growth Plate Abnormalities</data>
      <data key="d1">cause</data>
      <data key="d2">Abnormalities in the growth plates can lead to short stature.</data>
      <data key="d3">chunk-865f279e1b6a3e8bf38bf34c9c655cb3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217330</data>
      <data key="d6" />
    </node>
    <node id="Late Preterm Group">
      <data key="d0">Late Preterm Group</data>
      <data key="d1">demographic</data>
      <data key="d2">The late preterm group has a significantly higher incidence of short stature than other groups.</data>
      <data key="d3">chunk-865f279e1b6a3e8bf38bf34c9c655cb3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217330</data>
      <data key="d6" />
    </node>
    <node id="Term Group">
      <data key="d0">Term Group</data>
      <data key="d1">demographic</data>
      <data key="d2">The term group has a lower incidence of short stature compared to the late preterm group.</data>
      <data key="d3">chunk-865f279e1b6a3e8bf38bf34c9c655cb3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217330</data>
      <data key="d6" />
    </node>
    <node id="Clinical Evaluation">
      <data key="d0">Clinical Evaluation</data>
      <data key="d1">diagnosismethod</data>
      <data key="d2">A clinical evaluation is necessary to diagnose short stature in children.</data>
      <data key="d3">chunk-865f279e1b6a3e8bf38bf34c9c655cb3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217330</data>
      <data key="d6" />
    </node>
    <node id="Abnormal Growth Plate Closure">
      <data key="d0">Abnormal Growth Plate Closure</data>
      <data key="d1">condition</data>
      <data key="d2">Abnormal growth plate closure can lead to short stature due to inadequate bone growth.</data>
      <data key="d3">chunk-865f279e1b6a3e8bf38bf34c9c655cb3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217330</data>
      <data key="d6" />
    </node>
    <node id="Growth Hormone Deficiency">
      <data key="d0">Growth Hormone Deficiency</data>
      <data key="d1">cause</data>
      <data key="d2">A deficiency in growth hormone production is a common cause of abnormal growth plate closure.</data>
      <data key="d3">chunk-865f279e1b6a3e8bf38bf34c9c655cb3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217331</data>
      <data key="d6" />
    </node>
    <node id="Osteogenesis Imperfecta">
      <data key="d0">Osteogenesis Imperfecta</data>
      <data key="d1">condition</data>
      <data key="d2">Osteogenesis imperfecta is a genetic disorder causing brittle bones and often associated with short stature.</data>
      <data key="d3">chunk-865f279e1b6a3e8bf38bf34c9c655cb3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217331</data>
      <data key="d6" />
    </node>
    <node id="Chronic Kidney Disease">
      <data key="d0">Chronic Kidney Disease</data>
      <data key="d1">cause</data>
      <data key="d2">Chronic kidney disease can contribute to the development of growth hormone deficiency and subsequent short stature.</data>
      <data key="d3">chunk-865f279e1b6a3e8bf38bf34c9c655cb3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217331</data>
      <data key="d6" />
    </node>
    <node id="Deep Vein Thrombosis">
      <data key="d0">Deep Vein Thrombosis</data>
      <data key="d1">condition</data>
      <data key="d2">Deep vein thrombosis (DVT) is a medical condition where a blood clot forms in a deep vein, usually in the leg or arm. About half of people with DVT have no symptoms at all.&lt;SEP&gt;Deep vein thrombosis is a medical condition that can be diagnosed with D-dimer testing.</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f&lt;SEP&gt;chunk-e9f1c262e275060b69bdd0adbb9eaafe</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776245004</data>
      <data key="d6" />
    </node>
    <node id="Economy Class Syndrome">
      <data key="d0">Economy Class Syndrome</data>
      <data key="d1">data</data>
      <data key="d2">Economy class syndrome refers to a condition associated with deep vein thrombosis (DVT) that occurs while traveling in economy class on airplanes.</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217616</data>
      <data key="d6" />
    </node>
    <node id="Leg">
      <data key="d0">Leg</data>
      <data key="d1">location</data>
      <data key="d2">The leg is the part of the body where deep vein thrombosis (DVT) often affects.</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217617</data>
      <data key="d6" />
    </node>
    <node id="Arm">
      <data key="d0">Arm</data>
      <data key="d1">location</data>
      <data key="d2">The arm is another area affected by DVT, typically characterized by swelling and pain.</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217617</data>
      <data key="d6" />
    </node>
    <node id="Swelling">
      <data key="d0">Swelling</data>
      <data key="d1">symptom</data>
      <data key="d2">Swelling of the leg or arm can be a common symptom of deep vein thrombosis (DVT).</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217617</data>
      <data key="d6" />
    </node>
    <node id="Skin Warmth">
      <data key="d0">Skin Warmth</data>
      <data key="d1">symptom</data>
      <data key="d2">Warm skin on the affected area can be a symptom associated with deep vein thrombosis (DVT).</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217617</data>
      <data key="d6" />
    </node>
    <node id="Redness">
      <data key="d0">Redness</data>
      <data key="d1">symptom</data>
      <data key="d2">The skin may appear red due to deep vein thrombosis (DVT) in the affected part of the body.</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217617</data>
      <data key="d6" />
    </node>
    <node id="High Risk">
      <data key="d0">High Risk</data>
      <data key="d1">other</data>
      <data key="d2">High risk of severe gastrointestinal bleeding exists when taking Aspirin concurrently with Warfarin.</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217617</data>
      <data key="d6" />
    </node>
    <node id="Warfarin Induction">
      <data key="d0">Warfarin Induction</data>
      <data key="d1">mechanism</data>
      <data key="d2">Warfarin induces the production of anticoagulant proteins, which increases the risk of bleeding when combined with Aspirin.&lt;SEP&gt;Warfarin induces the production of the COX-1 enzyme, leading to its irreversible inhibition.</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f&lt;SEP&gt;chunk-05a062c31232f7d983bd96c0052adfc7</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776226353</data>
      <data key="d6" />
    </node>
    <node id="Pulmonary Embolism">
      <data key="d0">Pulmonary Embolism</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d2">Pulmonary embolism (PE) may be accompanied by difficulty breathing, faster heartbeat, or anxiety.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217619</data>
      <data key="d6" />
    </node>
    <node id="Warmth">
      <data key="d0">Warmth</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d2">Warm skin can be a symptom associated with DVT.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217619</data>
      <data key="d6" />
    </node>
    <node id="Lightheadedness">
      <data key="d0">Lightheadedness</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d2">Lightheadedness or fainting is a possible symptom of PE.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217621</data>
      <data key="d6" />
    </node>
    <node id="PE">
      <data key="d0">PE</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d2">People with DVT can also experience pulmonary embolism (PE) without symptoms.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217621</data>
      <data key="d6" />
    </node>
    <node id="Fainting">
      <data key="d0">Fainting</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d2">Lightheadedness or fainting can be associated with pulmonary embolism (PE).</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217621</data>
      <data key="d6" />
    </node>
    <node id="Difficulty Breathing">
      <data key="d0">Difficulty Breathing</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d2">Pulmonary embolism (PE) can lead to difficulty breathing.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217622</data>
      <data key="d6" />
    </node>
    <node id="Faster Heartbeat">
      <data key="d0">Faster Heartbeat</data>
      <data key="d3">chunk-f7c0f69e36eeb5da53429b84ed908e5f</data>
      <data key="d2">A faster heartbeat is a possible symptom of pulmonary embolism (PE).</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217625</data>
      <data key="d6" />
    </node>
    <node id="Gastrocolic Reflex">
      <data key="d0">Gastrocolic Reflex</data>
      <data key="d1">concept</data>
      <data key="d2">The gastrocolic reflex is a physiological reflex controlling motility in the gastrointestinal tract.</data>
      <data key="d3">chunk-7ca80ee55b1b2b3e022e9995f357ddd4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776218155</data>
      <data key="d6" />
    </node>
    <node id="Stomach">
      <data key="d0">Stomach</data>
      <data key="d1">location</data>
      <data key="d2">The stomach is involved in the gastrocolic reflex due to stretch and byproducts of digestion.</data>
      <data key="d3">chunk-7ca80ee55b1b2b3e022e9995f357ddd4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776218155</data>
      <data key="d6" />
    </node>
    <node id="Colon">
      <data key="d0">Colon</data>
      <data key="d1">location</data>
      <data key="d2">The colon's motility is affected in the gastrocolic reflex, with uneven distribution throughout.</data>
      <data key="d3">chunk-7ca80ee55b1b2b3e022e9995f357ddd4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776218155</data>
      <data key="d6" />
    </node>
    <node id="Sigmoid Colon">
      <data key="d0">Sigmoid Colon</data>
      <data key="d1">location</data>
      <data key="d2">The sigmoid colon is more greatly affected than the right side of the colon in terms of a phasic response.</data>
      <data key="d3">chunk-7ca80ee55b1b2b3e022e9995f357ddd4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776218155</data>
      <data key="d6" />
    </node>
    <node id="Ondansetron">
      <data key="d0">Ondansetron</data>
      <data key="d1">drug</data>
      <data key="d2">Ondansetron, a serotonin antagonist, decreases the tonic response to stretch associated with the gastrocolic reflex.</data>
      <data key="d3">chunk-7ca80ee55b1b2b3e022e9995f357ddd4</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776218155</data>
      <data key="d6" />
    </node>
    <node id="Clinical Document">
      <data key="d0">Clinical Document</data>
      <data key="d1">content</data>
      <data key="d2">A medical document that provides clinical details and treatment protocols.&lt;SEP&gt;A clinical document provides guidelines and information on medical topics like tricuspid regurgitation.</data>
      <data key="d3">chunk-99459c884b05410676ea284f38d1224a&lt;SEP&gt;chunk-0937f4b8bce4793fe181da12cd7f22c3</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776235419</data>
      <data key="d6" />
    </node>
    <node id="Existing Nevus">
      <data key="d0">Existing Nevus</data>
      <data key="d1">naturalobject</data>
      <data key="d2">An existing nevus on the skin that grows rapidly.</data>
      <data key="d3">chunk-99459c884b05410676ea284f38d1224a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776218207</data>
      <data key="d6" />
    </node>
    <node id="Symptoms of Dysplastic Nevus">
      <data key="d0">Symptoms of Dysplastic Nevus</data>
      <data key="d3">chunk-99459c884b05410676ea284f38d1224a</data>
      <data key="d2">Symptoms include a rapidly growing existing nevus, non-healing skin ulcers, pruritus, and bone pain..</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776218208</data>
      <data key="d6" />
    </node>
    <node id="Non-Healing Skin Ulcer">
      <data key="d0">Non-Healing Skin Ulcer</data>
      <data key="d3">chunk-99459c884b05410676ea284f38d1224a</data>
      <data key="d2">A non-healing skin ulcer is a symptom of dysplastic nevus.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776218209</data>
      <data key="d6" />
    </node>
    <node id="Bone Pain">
      <data key="d0">Bone Pain</data>
      <data key="d3">chunk-99459c884b05410676ea284f38d1224a</data>
