    </node>
    <node id="Necrosis">
      <data key="d0">Necrosis</data>
      <data key="d1">data</data>
      <data key="d2">Necrosis is the process of cell death, which can be observed in histopathological examination of lymph nodes and is often associated with certain types of lymphadenopathy or infections.</data>
      <data key="d3">chunk-052d9f2eb36a76fdb7920ef60341853c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203610</data>
