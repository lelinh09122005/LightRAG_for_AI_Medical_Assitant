    <node id="Plummer-Vinson Syndrome">
      <data key="d0">Plummer-Vinson Syndrome</data>
      <data key="d1">condition</data>
      <data key="d2">Plummer-Vinson syndrome is a rare acquired disorder characterized by difficulty swallowing due to esophageal webs or strictures, often associated with iron-deficiency anemia.</data>
      <data key="d3">chunk-e4be7ad6187377b3faeb10739c71599a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776202280</data>
