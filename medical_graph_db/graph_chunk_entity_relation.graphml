      <data key="d0">Renal Vasoconstriction Syndrome</data>
      <data key="d1">data</data>
      <data key="d2">Renal vasoconstriction syndrome is a complication of AERD affecting kidney function.</data>
      <data key="d3">chunk-5dbe00eb196766cfd6e87fb6bd43f658</data>
      <data key="d4">unknown_source</data>
