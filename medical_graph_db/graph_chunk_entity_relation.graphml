    <edge source="Peutz-Jeghers Syndrome" target="Gastrointestinal Tract">
      <data key="d7">1.0</data>
      <data key="d8">Patients with Peutz-Jeghers syndrome are at increased risk of developing gastrointestinal tract abnormalities.</data>
