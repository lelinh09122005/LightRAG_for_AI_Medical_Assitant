      <data key="d0">Congenitally Corrected Transposition of the Great Arteries</data>
      <data key="d1">concept</data>
      <data key="d2">This term has been disputed due to frequent occurrences of other abnormalities in patients with l-TGA.</data>
      <data key="d3">chunk-8e89c93cc380a668363623c506d07964</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776220972</data>
      <data key="d6" />
    </node>
    <node id="Atrioventricular Discordance">
      <data key="d0">Atrioventricular Discordance</data>
      <data key="d1">data</data>
      <data key="d2">A common description for segmental analysis of l-TGA.</data>
      <data key="d3">chunk-8e89c93cc380a668363623c506d07964</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776220972</data>
      <data key="d6" />
