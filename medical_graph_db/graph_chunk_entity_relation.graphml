      <data key="d0">Levo-Transposition of the Great Arteries</data>
      <data key="d1">data</data>
      <data key="d2">The levo-transposition of the great arteries is an acyanotic heart defect.</data>
      <data key="d3">chunk-8e89c93cc380a668363623c506d07964</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776220972</data>
