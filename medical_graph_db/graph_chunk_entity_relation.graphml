    <node id="Sinus Arrest">
      <data key="d0">Sinus Arrest</data>
      <data key="d1">event</data>
      <data key="d2">Sinus arrest is a condition where the sinoatrial node fails to initiate a heartbeat.</data>
      <data key="d3">chunk-b8f8e8de9e94ff3a0fb159812013b14d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776225527</data>
