      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d2">Vitamin B12 deficiency can cause subacute combined degeneration of the spinal cord.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231952</data>
      <data key="d6" />
    </node>
    <node id="Ataxic Gait">
      <data key="d0">Ataxic Gait</data>
      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d2">A decrease in nerve function due to Vitamin B12 deficiency may lead to an ataxic gait.</data>
