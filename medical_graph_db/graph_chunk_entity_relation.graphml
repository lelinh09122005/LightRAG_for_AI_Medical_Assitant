    <node id="Hematuria">
      <data key="d0">Hematuria</data>
      <data key="d1">symptom</data>
      <data key="d2">Hematuria refers to the presence of blood in the urine, often seen as a symptom of urethral cancer.</data>
      <data key="d3">chunk-1a63d042ddd8edeccd869d1b75dceedf</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231731</data>
