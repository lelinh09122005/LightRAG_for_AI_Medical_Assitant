    <node id="X-Linked Thrombocytopenia">
      <data key="d0">X-Linked Thrombocytopenia</data>
      <data key="d1">condition</data>
      <data key="d2">X-linked thrombocytopenia is a rare genetic disorder affecting primarily males, characterized by thrombocytopenia (low platelet count) and often ectodermal dysplasia due to mutations in the DP1 gene.</data>
      <data key="d3">chunk-e349119c3189688316f142a76b2f2e86</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203041</data>
