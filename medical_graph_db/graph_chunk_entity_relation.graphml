    <node id="Hypertrophic osteoarthropathy">
      <data key="d0">Hypertrophic osteoarthropathy</data>
      <data key="d1">sign</data>
      <data key="d2">A musculoskeletal disorder that results in swelling and pain of the joints, often affecting hands and feet, potentially seen in patients with liver disease.</data>
      <data key="d3">chunk-a45c0433e861eaa94dbda4172985c8d7</data>
