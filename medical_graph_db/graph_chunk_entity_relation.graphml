      <data key="d0">Pancreatitis</data>
      <data key="d3">chunk-d9f255691d2c2b02c84652be9d8c3d51&lt;SEP&gt;chunk-769ba65764860ea7658e8357d16cb900</data>
      <data key="d2">Pancreatitis can occur in patients with Alstrom syndrome due to various reasons related to the disorder.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776206974</data>
