    <node id="Cholesterol Emboli">
      <data key="d0">Cholesterol Emboli</data>
      <data key="d1">organization</data>
      <data key="d2">Cholesterol emboli are the primary cause of AERD and renal vasoconstriction syndrome.</data>
      <data key="d3">chunk-5dbe00eb196766cfd6e87fb6bd43f658</data>
