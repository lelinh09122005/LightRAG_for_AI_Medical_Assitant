    <node id="Electrocardiography">
      <data key="d0">Electrocardiography</data>
      <data key="d1">method</data>
      <data key="d2">Electrocardiography is a medical procedure used to measure the electrical activity of the heart.&lt;SEP&gt;Resting electrocardiography assesses the risk associated with stable angina.</data>
      <data key="d3">chunk-0d9df8319256ab3c418f8c73ac00fad8&lt;SEP&gt;chunk-3700d76f4df2ab8f24d3bd57b94e911f&lt;SEP&gt;chunk-a5970e312d13536cfdcd7ca01d35e2f8</data>
