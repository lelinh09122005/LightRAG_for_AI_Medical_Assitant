      <data key="d3">chunk-2f889d1bbbba1e31fe8113c210d59475</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776209346</data>
      <data key="d6" />
    </node>
    <node id="Pruritus">
      <data key="d0">Pruritus</data>
      <data key="d1">symptom</data>
      <data key="d2">Pruritus, or itching, is the most significant symptom of vulvovaginitis.</data>
      <data key="d3">chunk-2f889d1bbbba1e31fe8113c210d59475&lt;SEP&gt;chunk-99459c884b05410676ea284f38d1224a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776209346</data>
      <data key="d6" />
    </node>
    <node id="Vaginal Discharge">
      <data key="d0">Vaginal Discharge</data>
      <data key="d1">content</data>
      <data key="d2">A "cottage cheese-like" vaginal discharge is a common characteristic of vulvovaginitis.</data>
      <data key="d3">chunk-2f889d1bbbba1e31fe8113c210d59475</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776209346</data>
      <data key="d6" />
    </node>
    <node id="Dysuria">
      <data key="d0">Dysuria</data>
      <data key="d1">symptom</data>
      <data key="d2">Pain on urination, or dysuria, is another symptom of vulvovaginitis.</data>
      <data key="d3">chunk-2f889d1bbbba1e31fe8113c210d59475</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776209346</data>
      <data key="d6" />
    </node>
    <node id="Dyspareunia">
      <data key="d0">Dyspareunia</data>
      <data key="d1">symptom</data>
      <data key="d2">Pain during sexual intercourse, or dyspareunia, is also associated with vulvovaginitis.</data>
      <data key="d3">chunk-2f889d1bbbba1e31fe8113c210d59475</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776209346</data>
      <data key="d6" />
