      <data key="d1">symptom</data>
      <data key="d2">A lump or thickness in the perineum or penis can be a visible sign of urethral cancer.</data>
      <data key="d3">chunk-1a63d042ddd8edeccd869d1b75dceedf</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231732</data>
