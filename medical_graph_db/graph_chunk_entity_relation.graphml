    </node>
    <node id="Obesity">
      <data key="d0">Obesity</data>
      <data key="d1">data</data>
      <data key="d2">Excess weight and obesity significantly increase the risk of developing metabolic syndrome.&lt;SEP&gt;Excess body weight can contribute to the development of insulin resistance, a precursor to HHS.</data>
      <data key="d3">chunk-14491e922b3c111ccfd99b482d34948b&lt;SEP&gt;chunk-18b3a59bf7f5ccc18f7641e35b20249f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776232341</data>
      <data key="d6" />
    </node>
    <node id="Type 2 Diabetes">
      <data key="d0">Type 2 Diabetes</data>
      <data key="d1">concept</data>
      <data key="d2">Type 2 diabetes is a chronic condition characterized by insulin resistance and impaired insulin secretion.</data>
      <data key="d3">chunk-14491e922b3c111ccfd99b482d34948b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776212197</data>
