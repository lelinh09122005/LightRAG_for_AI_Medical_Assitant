      <data key="d0">Rift Valley Fever</data>
      <data key="d1">disease</data>
      <data key="d2">Rift Valley fever is another viral hemorrhagic fever that necessitates differential diagnosis with Marburg hemorrhagic fever.</data>
      <data key="d3">chunk-ef4d5f4542528f658127572749676234</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776201992</data>
