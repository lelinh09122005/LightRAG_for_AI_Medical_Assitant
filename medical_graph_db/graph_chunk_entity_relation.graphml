    <node id="Stool Hardening">
      <data key="d0">Stool Hardening</data>
      <data key="d1">symptom</data>
      <data key="d2">Stool hardening refers to the condition of having hardened stool during defecation.</data>
      <data key="d3">chunk-58320e3f9e2aeb800e533ad8fd0fa94e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776199943</data>
