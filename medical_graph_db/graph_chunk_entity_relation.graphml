    </node>
    <node id="Melatonin">
      <data key="d0">Melatonin</data>
      <data key="d1">content</data>
      <data key="d2">Melatonin is a hormone involved in regulating sleep-wake cycles, which can be affected by Vitamin B12 deficiency.</data>
      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231949</data>
      <data key="d6" />
    </node>
    <node id="Perinicious Anemia">
      <data key="d0">Perinicious Anemia</data>
      <data key="d1">data</data>
      <data key="d2">Perinicious anemia is a hereditary form of Vitamin B12 deficiency that affects energy production and nerve function.</data>
      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231949</data>
      <data key="d6" />
    </node>
    <node id="Vitamin B12 Deficiency">
      <data key="d0">Vitamin B12 Deficiency</data>
      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d2">Vitamin B12 deficiency causes tiredness, leading to decreased productivity.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231950</data>
      <data key="d6" />
    </node>
    <node id="Bipolar Disorder">
      <data key="d0">Bipolar Disorder</data>
      <data key="d3">chunk-64464fe427daf4856c5208850d191d79&lt;SEP&gt;chunk-af76a19d7c4899519758f59183dd1222</data>
      <data key="d2">Bipolar disorder appears to be genetically linked to pernicious anemia, a hereditary form of Vitamin B12 deficiency.&lt;SEP&gt;Bipolar disorders are types of mood disorders that involve extreme shifts in mood and energy levels.</data>
      <data key="d1">mentaldisorder</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776232075</data>
      <data key="d6" />
    </node>
