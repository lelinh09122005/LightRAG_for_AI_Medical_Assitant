    </edge>
    <edge source="Aortic Valve" target="Bicuspid Aortic Valve">
      <data key="d7">1.0</data>
      <data key="d8">Differentiation may be made between an anatomically bicuspid valve and an anatomically trileaflet valve with fused comissures ("functionally-bicuspid valve").</data>
      <data key="d9">anatomical distinction,differentiation</data>
      <data key="d10">chunk-c5d390cb21e6dd1e2d80ae8661e921a2</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776234703</data>
      <data key="d13" />
    </edge>
    <edge source="Aortic Valve" target="Hypoplastic Left Heart Syndrome">
      <data key="d7">2.0</data>
      <data key="d8">The aortic valve is also an incomplete development in hypoplastic left heart syndrome.&lt;SEP&gt;The aortic valve's incomplete development also plays a role in hypoplastic left heart syndrome.</data>
      <data key="d9">affected part,anatomical location</data>
      <data key="d10">chunk-ea34669e3dc11beced307b643d8c67a4</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776239403</data>
