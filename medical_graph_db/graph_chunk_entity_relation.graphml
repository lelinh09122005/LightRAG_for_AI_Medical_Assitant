    <node id="ST-elevation Myocardial Infarction">
      <data key="d0">ST-elevation Myocardial Infarction</data>
      <data key="d1">disease</data>
      <data key="d2">ST-elevation myocardial infarction is a type of heart attack.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203989</data>
      <data key="d6" />
    </node>
    <node id="Reinfarction">
      <data key="d0">Reinfarction</data>
      <data key="d1">event</data>
      <data key="d2">Reinfarction, or reocclusion of the infarct-related artery, can lead to a doubling of mortality.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203989</data>
      <data key="d6" />
    </node>
    <node id="Fibrinolytic Therapy">
      <data key="d0">Fibrinolytic Therapy</data>
      <data key="d1">method</data>
      <data key="d2">Fibrinolytic therapy is used to treat ST-elevation myocardial infarction.&lt;SEP&gt;Fibrinolytic therapy is a treatment approach used in STEMI that involves administering fibrinolytic agents to dissolve blood clots.&lt;SEP&gt;Fibrinolytic therapy is a treatment approach using drugs that dissolve clots in the coronary arteries.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28&lt;SEP&gt;chunk-fa7b0387cb6903fcd84f7bdac107fe37&lt;SEP&gt;chunk-88cd08eb7d49a30bc0bc72846f427aff</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776228426</data>
      <data key="d6" />
    </node>
    <node id="Bivalirudin Monotherapy">
      <data key="d0">Bivalirudin Monotherapy</data>
      <data key="d1">data</data>
      <data key="d2">Bivalirudin monotherapy has been associated with stent thrombosis in patients undergoing primary PCI.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203990</data>
      <data key="d6" />
    </node>
    <node id="Primary PCI">
      <data key="d0">Primary PCI</data>
      <data key="d1">method</data>
      <data key="d2">Primary PCI is a treatment for ST-elevation myocardial infarction.&lt;SEP&gt;Primary PCI (percutaneous coronary intervention) is defined as the performance of percutaneous coronary intervention in the setting of ST elevation MI.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28&lt;SEP&gt;chunk-fa7b0387cb6903fcd84f7bdac107fe37</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776207373</data>
      <data key="d6" />
    </node>
    <node id="Aggressive Antiplatelet Therapy">
      <data key="d0">Aggressive Antiplatelet Therapy</data>
      <data key="d1">method</data>
      <data key="d2">Aggressive antiplatelet therapy can minimize the risk of reinfarction in patients undergoing primary PCI.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203990</data>
      <data key="d6" />
    </node>
    <node id="Antiplatelet Therapy">
      <data key="d0">Antiplatelet Therapy</data>
      <data key="d1">method</data>
      <data key="d2">Antiplatelet therapy is used to prevent platelets from clumping and causing a blockage in blood vessels.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203990</data>
      <data key="d6" />
    </node>
    <node id="Papillary Muscle Rupture">
      <data key="d0">Papillary Muscle Rupture</data>
      <data key="d1">complication</data>
      <data key="d2">Papillary muscle rupture can lead to severe mitral regurgitation and pulmonary edema.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203990</data>
      <data key="d6" />
    </node>
    <node id="Posterior Papillary Muscle Rupture">
      <data key="d0">Posterior Papillary Muscle Rupture</data>
      <data key="d1">complication</data>
      <data key="d2">Posterior papillary muscle rupture is more common than anterior papillary muscle rupture.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203990</data>
      <data key="d6" />
    </node>
    <node id="Anterior Papillary Muscle">
      <data key="d0">Anterior Papillary Muscle</data>
      <data key="d1">location</data>
      <data key="d2">The anterior papillary muscle receives a dual blood supply from the left anterior descending artery and the circumflex artery.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203990</data>
      <data key="d6" />
    </node>
    <node id="Septal Rupture">
      <data key="d0">Septal Rupture</data>
      <data key="d1">complication</data>
      <data key="d2">Septal rupture can lead to chest pain, shortness of breath, and symptoms of low-output cardiogenic shock.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203990</data>
      <data key="d6" />
    </node>
    <node id="Free-Wall Rupture">
      <data key="d0">Free-Wall Rupture</data>
      <data key="d1">complication</data>
      <data key="d2">Free-wall rupture usually leads to hemopericardium and abrupt circulatory collapse.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203991</data>
      <data key="d6" />
    </node>
    <node id="Atrial Fibrillation">
      <data key="d0">Atrial Fibrillation</data>
      <data key="d1">condition</data>
      <data key="d2">New onset atrial fibrillation in the setting of STEMI is associated with a very poor prognosis.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28</data>
      <data key="d4">unknown_source</data>
