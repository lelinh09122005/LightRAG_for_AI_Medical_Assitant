      <data key="d0">Abnormal Calcium Metabolism</data>
      <data key="d1">concept</data>
      <data key="d2">Abnormal calcium metabolism in cardiac myocytes can lead to various cardiac arrhythmias and dysfunction.</data>
      <data key="d3">chunk-b8f8e8de9e94ff3a0fb159812013b14d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776225528</data>
