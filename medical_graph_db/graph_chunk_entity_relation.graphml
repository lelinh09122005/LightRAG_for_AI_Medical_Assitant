    <node id="Cross-Matching">
      <data key="d0">Cross-Matching</data>
      <data key="d1">method</data>
      <data key="d2">Cross-matching is a test used to check compatibility between donor and recipient blood by mixing their sera.</data>
      <data key="d3">chunk-17717aab6acc128a83824d9e8317ea4f</data>
      <data key="d4">unknown_source</data>
