    </node>
    <node id="Hypertriglyceridemia">
      <data key="d0">Hypertriglyceridemia</data>
      <data key="d1">cause</data>
      <data key="d2">High levels of triglycerides in the blood are another contributing factor to metabolic syndrome.</data>
      <data key="d3">chunk-14491e922b3c111ccfd99b482d34948b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776212197</data>
