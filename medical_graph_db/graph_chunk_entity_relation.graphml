      <data key="d0">Epithelioid Cells</data>
      <data key="d1">data</data>
      <data key="d2">Epithelioid cells are a type of cell seen in histopathological examination of lymph nodes, often indicative of certain types of lymphadenopathy or granulomatous inflammation.</data>
      <data key="d3">chunk-052d9f2eb36a76fdb7920ef60341853c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203610</data>
