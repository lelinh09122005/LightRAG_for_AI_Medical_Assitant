    <node id="Neoplastic Meningitis">
      <data key="d0">Neoplastic Meningitis</data>
      <data key="d1">disease</data>
      <data key="d2">Neoplastic meningitis is a medical condition involving neoplastic growth in the meninges.&lt;SEP&gt;Neoplastic meningitis is a condition where the meninges become inflamed due to cancerous cells, leading to a range of complications and potential outcomes.</data>
      <data key="d3">chunk-b5c6f77b16e16e44d387190c97da1df2&lt;SEP&gt;chunk-2f9f6e0c1ac72f2d9f132ba1b3ab8be3</data>
