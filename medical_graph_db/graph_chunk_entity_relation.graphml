      <data key="d0">Tingible Body Macrophages</data>
      <data key="d1">data</data>
      <data key="d2">Tingible body macrophages are abnormal macrophages found in lymph nodes, often associated with follicular hyperplasia and other conditions.</data>
      <data key="d3">chunk-052d9f2eb36a76fdb7920ef60341853c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203609</data>
