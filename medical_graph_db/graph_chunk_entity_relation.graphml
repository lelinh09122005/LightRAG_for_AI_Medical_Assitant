    <node id="Lisinopril">
      <data key="d0">Lisinopril</data>
      <data key="d1">drug</data>
      <data key="d2">Lisinopril is a medication commonly prescribed to treat congestive heart failure.&lt;SEP&gt;Lisinopril is a medication commonly prescribed to treat hypertension but can cause a persistent dry cough.</data>
      <data key="d3">chunk-331beb4d681443473668b1b86bc0a556&lt;SEP&gt;chunk-0392546b4be8990b5651990bc3c882c3&lt;SEP&gt;chunk-120f6a61156fe5cb9fa55fd78d0d09df&lt;SEP&gt;chunk-81ca909fcf7ec8b326421ab4d2766d19&lt;SEP&gt;chunk-be0afdf0753c12d1860d48df1a690238</data>
