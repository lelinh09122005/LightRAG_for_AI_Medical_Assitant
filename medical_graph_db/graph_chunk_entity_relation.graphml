      <data key="d0">Cervical Cancer</data>
      <data key="d1">disease</data>
      <data key="d2">Cervical cancer is a type of cancer affecting the cells of the cervix.</data>
      <data key="d3">chunk-b74be085e56dc55429b21339be974dcb</data>
      <data key="d4">unknown_source</data>
