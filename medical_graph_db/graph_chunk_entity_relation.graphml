      <data key="d13" />
    </edge>
    <edge source="Aortic Sinus" target="Ascending Aorta">
      <data key="d7">1.0</data>
      <data key="d8">The aortic sinus is located just above the aortic valve in the ascending aorta.</data>
      <data key="d9">adjacent structure,anatomical location</data>
      <data key="d10">chunk-830f7c80bbd34b9d892fbd4d5954c36a</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776198948</data>
      <data key="d13" />
    </edge>
    <edge source="Aortic Sinus" target="Aortic Valve">
      <data key="d7">1.0</data>
      <data key="d8">The aortic valve controls blood flow from the left ventricle to the rest of the body through the ascending aorta.</data>
      <data key="d9">junction,regulates blood flow</data>
      <data key="d10">chunk-830f7c80bbd34b9d892fbd4d5954c36a</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776198948</data>
      <data key="d13" />
    </edge>
    <edge source="Ascending Aorta" target="Left Aortic Sinus">
      <data key="d7">1.0</data>
      <data key="d8">The left aortic sinus gives rise to the left coronary artery in the ascending aorta.</data>
      <data key="d9">connection,giving rise to vessel</data>
      <data key="d10">chunk-830f7c80bbd34b9d892fbd4d5954c36a</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776198948</data>
      <data key="d13" />
    </edge>
    <edge source="Ascending Aorta" target="Right Aortic Sinus">
      <data key="d7">1.0</data>
      <data key="d8">The right aortic sinus gives rise to the right coronary artery in the ascending aorta.</data>
      <data key="d9">connection,giving rise to vessel</data>
      <data key="d10">chunk-830f7c80bbd34b9d892fbd4d5954c36a</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776198949</data>
      <data key="d13" />
    </edge>
    <edge source="Aortic Valve" target="Posterior Aortic Sinus">
      <data key="d7">1.0</data>
      <data key="d8">The posterior aortic sinus is separated from the left and right aortic sinuses by the aortic valve.</data>
      <data key="d9">distinct from other sinuses,separation</data>
      <data key="d10">chunk-830f7c80bbd34b9d892fbd4d5954c36a</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776198948</data>
      <data key="d13" />
    </edge>
    <edge source="Aortic Valve" target="Cardiac MRI">
