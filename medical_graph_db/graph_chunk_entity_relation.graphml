    <node id="Cancer">
      <data key="d0">Cancer</data>
      <data key="d1">condition</data>
      <data key="d2">Cancer is a disease that may be treated with kinase inhibitors.&lt;SEP&gt;Cancer is a disease characterized by uncontrolled cell growth and division, which can be associated with Peutz-Jeghers syndrome.</data>
      <data key="d3">chunk-e0187e7708a45e4db3589f0e72ca7402&lt;SEP&gt;chunk-fb604501a5857dd9d711ed6904f14977&lt;SEP&gt;chunk-8442ec3153c9dbbd0097bc0cb7253340&lt;SEP&gt;chunk-27ddd07c03c4a22cb59ce2d699b0d3f2</data>
      <data key="d4">unknown_source</data>
