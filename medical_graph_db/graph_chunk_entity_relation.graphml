      <data key="d13" />
    </edge>
    <edge source="Ichthyosis Vulgaris" target="Fine White Scales">
      <data key="d7">1.0</data>
      <data key="d8">Fine white scales are another symptom of ichthyosis vulgaris.</data>
      <data key="d9">symptom</data>
      <data key="d10">chunk-7714b28896e0f4b35847062fac4e9375</data>
