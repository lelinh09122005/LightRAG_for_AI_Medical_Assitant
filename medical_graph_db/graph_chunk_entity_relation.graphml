    <node id="Caffeine Intake">
      <data key="d0">Caffeine Intake</data>
      <data key="d1">triggers</data>
      <data key="d2">Caffeine consumption is a trigger that can exacerbate or induce palpitations.</data>
      <data key="d3">chunk-5d5d870ad6493ac1d369fb7c8bf144bb</data>
