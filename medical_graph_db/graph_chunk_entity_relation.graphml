    </node>
    <node id="Sleep Disturbances">
      <data key="d0">Sleep Disturbances</data>
      <data key="d1">sideeffect</data>
      <data key="d2">Sleep disturbances can occur due to the role of melatonin in regulating sleep-wake cycles affected by Vitamin B12 deficiency.</data>
      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231949</data>
      <data key="d6" />
    </node>
    <node id="Pineal Gland">
      <data key="d0">Pineal Gland</data>
      <data key="d1">organ</data>
      <data key="d2">The pineal gland plays a crucial role in regulating the body's circadian rhythms, which can be impacted by Vitamin B12 deficiency.</data>
      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231949</data>
