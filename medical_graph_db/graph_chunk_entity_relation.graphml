      <data key="d0">Anemia of Chronic Disease</data>
      <data key="d1">concept</data>
      <data key="d2">Anemia of chronic disease is a condition where patients with chronic diseases like rheumatoid arthritis or cancer develop reduced red blood cell count and function.</data>
