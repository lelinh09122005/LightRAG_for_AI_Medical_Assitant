    <node id="Burn">
      <data key="d0">Burn</data>
      <data key="d1">concept</data>
      <data key="d2">A burn is a thermal injury that can cause damage to the skin and underlying tissues.</data>
      <data key="d3">chunk-a5a80498abe28fa59b46e83f179e390b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776207343</data>
