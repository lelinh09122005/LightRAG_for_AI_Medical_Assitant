    <node id="Statins">
      <data key="d0">Statins</data>
      <data key="d1">content</data>
      <data key="d2">Statins have been found to improve outcomes in patients with AERD by reducing cholesterol levels and improving blood vessel function.</data>
      <data key="d3">chunk-5dbe00eb196766cfd6e87fb6bd43f658</data>
