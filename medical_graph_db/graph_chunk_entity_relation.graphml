    </node>
    <node id="Sinus Bradycardia">
      <data key="d0">Sinus Bradycardia</data>
      <data key="d1">condition</data>
      <data key="d2">Sinus bradycardia refers to an abnormally slow heart rate originating from the sinoatrial node.</data>
      <data key="d3">chunk-b8f8e8de9e94ff3a0fb159812013b14d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776225527</data>
      <data key="d6" />
    </node>
    <node id="Complete Heart Block">
      <data key="d0">Complete Heart Block</data>
      <data key="d1">condition</data>
      <data key="d2">A complete heart block is a severe condition where the electrical impulses are completely blocked between the atria and ventricles.</data>
      <data key="d3">chunk-b8f8e8de9e94ff3a0fb159812013b14d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776225527</data>
