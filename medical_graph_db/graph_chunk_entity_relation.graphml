    </edge>
    <edge source="Gastrointestinal Tract" target="Polyps">
      <data key="d7">1.0</data>
      <data key="d8">Polyps are abnormal growths on the walls of the gastrointestinal tract in Peutz-Jeghers syndrome patients.</data>
      <data key="d9">condition,pathological feature</data>
      <data key="d10">chunk-8442ec3153c9dbbd0097bc0cb7253340</data>
