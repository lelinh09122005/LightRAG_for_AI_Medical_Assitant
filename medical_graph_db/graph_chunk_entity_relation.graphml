    <node id="Constipation">
      <data key="d0">Constipation</data>
      <data key="d1">syndrome</data>
      <data key="d2">Constipation is a syndrome characterized by difficulty passing stool, infrequent bowel movements, hard stool, or incomplete evacuation.</data>
      <data key="d3">chunk-58320e3f9e2aeb800e533ad8fd0fa94e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776199943</data>
