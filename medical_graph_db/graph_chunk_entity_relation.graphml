    <node id="Hepatitis E">
      <data key="d0">Hepatitis E</data>
      <data key="d1">disease</data>
      <data key="d2">Hepatitis E is a liver infection that can be self-limited in most immunocompetent patients and carries varying levels of risk depending on individual circumstances.&lt;SEP&gt;A range of outcomes and complications can occur in patients infected with Hepatitis E, including chronic infection or severe mortality rates.</data>
      <data key="d3">chunk-f6afd96faad2cc5882099be8abb7943d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776216402</data>
      <data key="d6" />
    </node>
    <node id="Immunocompetent Patients">
      <data key="d0">Immunocompetent Patients</data>
      <data key="d1">persongroup</data>
      <data key="d2">Immunocompetent individuals generally have good outcomes with Hepatitis E, as the disease is typically self-limiting.</data>
      <data key="d3">chunk-f6afd96faad2cc5882099be8abb7943d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776216402</data>
      <data key="d6" />
    </node>
    <node id="End-Stage Liver Disease">
      <data key="d0">End-Stage Liver Disease</data>
      <data key="d1">condition</data>
      <data key="d2">The prognosis for patients with end-stage liver disease is generally poor when it comes to managing Hepatitis E.</data>
      <data key="d3">chunk-f6afd96faad2cc5882099be8abb7943d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776216402</data>
      <data key="d6" />
    </node>
    <node id="Fulminant Hepatic Failure">
      <data key="d0">Fulminant Hepatic Failure</data>
      <data key="d1">condition</data>
      <data key="d2">Fulminant hepatic failure can be a fatal complication of Hepatitis E, especially in pregnant women.</data>
      <data key="d3">chunk-f6afd96faad2cc5882099be8abb7943d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776216402</data>
      <data key="d6" />
    </node>
    <node id="Hemorrhage">
      <data key="d0">Hemorrhage</data>
      <data key="d1">medicalprocedure</data>
      <data key="d2">Hemorrhage is a potential cause of mortality among hospitalized patients with Hepatitis E.</data>
      <data key="d3">chunk-f6afd96faad2cc5882099be8abb7943d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776216402</data>
      <data key="d6" />
    </node>
    <node id="Pregnancy-Related Morbidity and Mortality">
      <data key="d0">Pregnancy-Related Morbidity and Mortality</data>
      <data key="d1">condition</data>
      <data key="d2">The mortality rate among pregnant women is 10 - 25% due to fulminant hepatic failure, hemorrhage or eclampsia.</data>
      <data key="d3">chunk-f6afd96faad2cc5882099be8abb7943d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776216402</data>
      <data key="d6" />
    </node>
    <node id="Eclampsia">
      <data key="d0">Eclampsia</data>
      <data key="d1">event</data>
      <data key="d2">Eclampsia is a severe neurological complication that can occur in pregnant women with Hepatitis E.&lt;SEP&gt;Eclampsia is a severe complication of preeclampsia.</data>
      <data key="d3">chunk-f6afd96faad2cc5882099be8abb7943d&lt;SEP&gt;chunk-bc3c55524a3cf351aed82cb5c8b740ea</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776230192</data>
      <data key="d6" />
    </node>
    <node id="Hepatitis A">
      <data key="d0">Hepatitis A</data>
      <data key="d1">disease</data>
      <data key="d2">Chronic Hepatitis can occur in patients infected with Hepatitis A.</data>
      <data key="d3">chunk-f6afd96faad2cc5882099be8abb7943d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776216403</data>
      <data key="d6" />
    </node>
    <node id="Chronic Hepatitis">
      <data key="d0">Chronic Hepatitis</data>
      <data key="d3">chunk-f6afd96faad2cc5882099be8abb7943d</data>
      <data key="d2">While most immunocompetent individuals have good outcomes with Hepatitis E, some can develop chronic infection.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776216404</data>
      <data key="d6" />
    </node>
    <node id="Hospitalized Patients">
      <data key="d0">Hospitalized Patients</data>
      <data key="d3">chunk-f6afd96faad2cc5882099be8abb7943d</data>
      <data key="d2">The mortality rate for hospitalized patients with Hepatitis E ranges from 0.5 - 4%.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776216407</data>
      <data key="d6" />
    </node>
    <node id="Sclerosing Mesenteritis">
      <data key="d0">Sclerosing Mesenteritis</data>
      <data key="d1">condition</data>
      <data key="d2">Sclerosing mesenteritis is an inflammatory disease affecting the small intestine.</data>
      <data key="d3">chunk-da72dd973491937bc3732c1313c7d98b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776216615</data>
      <data key="d6" />
