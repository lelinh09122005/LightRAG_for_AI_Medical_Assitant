    <node id="Sympathetic Division">
      <data key="d0">Sympathetic Division</data>
      <data key="d1">concept</data>
      <data key="d2">The sympathetic division is one of the two branches of the autonomic nervous system that promotes 'fight or flight' responses in the body.</data>
      <data key="d3">chunk-0d9df8319256ab3c418f8c73ac00fad8</data>
      <data key="d4">unknown_source</data>
