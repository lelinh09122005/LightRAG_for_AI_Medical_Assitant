      <data key="d0">Tactile Fremitus</data>
      <data key="d1">symptom</data>
      <data key="d2">Tactile fremitus refers to the sensation of vibrations felt on the chest, diminished in cases of pleural effusion.</data>
      <data key="d3">chunk-c16a4c902adb4dbeda6878a55d31bfe9</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776209589</data>
      <data key="d6" />
    </node>
    <node id="Chest Cavity">
      <data key="d0">Chest Cavity</data>
      <data key="d1">anatomicalstructure</data>
      <data key="d2">The chest cavity refers to the area of the thorax that contains the lungs, heart, and other vital organs.&lt;SEP&gt;The chest cavity is the region where the lungs and pleural space are located.</data>
      <data key="d3">chunk-c16a4c902adb4dbeda6878a55d31bfe9&lt;SEP&gt;chunk-6dafb4a051e19d074b1f7f9b7e5a69c4</data>
      <data key="d4">unknown_source</data>
