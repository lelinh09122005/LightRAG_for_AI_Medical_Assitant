    <node id="Lumbosacral Hemangioma">
      <data key="d0">Lumbosacral Hemangioma</data>
      <data key="d1">location</data>
      <data key="d2">Lumbosacral hemangioma refers to a specific location and manifestation of this vascular anomaly in the lumbosacral region.</data>
      <data key="d3">chunk-350836c0cbd5f38144bfd64dc2e11cd0</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236144</data>
      <data key="d6" />
    </node>
