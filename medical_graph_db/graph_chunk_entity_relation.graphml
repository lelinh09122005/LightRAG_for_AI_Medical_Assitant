      <data key="d1">complication</data>
      <data key="d2">Heart failure can occur as a result of prolonged or recurrent heart attack.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203992</data>
