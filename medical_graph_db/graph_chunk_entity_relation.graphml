    <node id="Schizophrenia">
      <data key="d0">Schizophrenia</data>
      <data key="d1">mentaldisorder</data>
      <data key="d2">Schizophrenia is a chronic and severe mental disorder that affects how a person thinks, feels, and behaves.</data>
      <data key="d3">chunk-af76a19d7c4899519758f59183dd1222</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776232075</data>
      <data key="d6" />
    </node>
    <node id="Neurodevelopmental Disorder">
      <data key="d0">Neurodevelopmental Disorder</data>
      <data key="d1">condition</data>
      <data key="d2">Neurodevelopmental disorders are conditions that affect brain development and function.</data>
      <data key="d3">chunk-af76a19d7c4899519758f59183dd1222</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776232075</data>
