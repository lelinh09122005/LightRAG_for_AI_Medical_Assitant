    </node>
    <node id="Granulomas">
      <data key="d0">Granulomas</data>
      <data key="d1">data</data>
      <data key="d2">Granulomas are aggregations of immune cells that form in response to inflammation, often seen in conditions like sarcoidosis or tuberculosis.</data>
      <data key="d3">chunk-052d9f2eb36a76fdb7920ef60341853c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203610</data>
