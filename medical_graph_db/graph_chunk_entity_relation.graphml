    <node id="Alstrom Syndrome">
      <data key="d0">Alstrom Syndrome</data>
      <data key="d1">naturalobject</data>
      <data key="d2">Alstrom syndrome is a rare genetic disorder affecting the eyes, ears, kidneys, and pancreas. It can cause progressive hearing loss and blindness due to various complications associated with the condition.</data>
      <data key="d3">chunk-d9f255691d2c2b02c84652be9d8c3d51</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776206971</data>
