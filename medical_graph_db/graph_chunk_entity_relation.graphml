    </node>
    <node id="Digestive System Overload">
      <data key="d0">Digestive System Overload</data>
      <data key="d1">concept</data>
      <data key="d2">A digestive system overload occurs when the body's digestive capacity is overwhelmed by an excessive amount of food or waste.</data>
      <data key="d3">chunk-58320e3f9e2aeb800e533ad8fd0fa94e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776199943</data>
      <data key="d6" />
    </node>
    <node id="Food Intolerance">
      <data key="d0">Food Intolerance</data>
      <data key="d1">concept</data>
      <data key="d2">A food intolerance occurs when an individual's body is unable to properly digest or process certain foods, leading to discomfort and other symptoms.</data>
      <data key="d3">chunk-58320e3f9e2aeb800e533ad8fd0fa94e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776199944</data>
      <data key="d6" />
    </node>
    <node id="Underlying Medical Condition">
      <data key="d0">Underlying Medical Condition</data>
      <data key="d1">concept</data>
      <data key="d2">An underlying medical condition can contribute to constipation, such as hypothyroidism or diabetes.</data>
      <data key="d3">chunk-58320e3f9e2aeb800e533ad8fd0fa94e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776199944</data>
