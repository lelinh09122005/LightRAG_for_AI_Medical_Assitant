      <data key="d0">Ventriculoarterial Discordance</data>
      <data key="d1">data</data>
      <data key="d2">Another term describing the ventriculoarterial discordance in l-TGA patients.</data>
      <data key="d3">chunk-8e89c93cc380a668363623c506d07964</data>
