      <data key="d13" />
    </edge>
    <edge source="Osteoporosis" target="Endometrial Ablation">
      <data key="d7">1.0</data>
      <data key="d8">There is limited information available on the interaction between endometrial ablation and osteoporosis; however, patients with osteoporosis should be monitored closely after the procedure.</data>
      <data key="d9">post-procedure care,precaution</data>
      <data key="d10">chunk-40324022a0e3a72859b0d0b0a9c2b089</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776217037</data>
      <data key="d13" />
    </edge>
    <edge source="Osteoporosis" target="Estrogen Deficiency">
      <data key="d7">1.0</data>
      <data key="d8">Estrogen deficiency stimulates osteoclastic activity, weakening bones and increasing the risk of fractures.</data>
      <data key="d9">biological process</data>
      <data key="d10">chunk-e80dc7bcd1293375ca72b55372764fe1</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776233326</data>
      <data key="d13" />
    </edge>
    <edge source="Osteoporosis" target="Menopause">
      <data key="d7">1.0</data>
      <data key="d8">Menopause contributes to osteoporosis by increasing osteoclastic activity, which weakens bones.</data>
      <data key="d9">cause and effect</data>
      <data key="d10">chunk-e80dc7bcd1293375ca72b55372764fe1</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776233326</data>
