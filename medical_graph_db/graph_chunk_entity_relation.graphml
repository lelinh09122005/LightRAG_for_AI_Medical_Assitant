      <data key="d1">location</data>
      <data key="d2">The cardiac myocyte is the basic unit of the heart's muscle tissue responsible for contraction and relaxation.</data>
      <data key="d3">chunk-b8f8e8de9e94ff3a0fb159812013b14d</data>
      <data key="d4">unknown_source</data>
