    <node id="Bernard-Soulier Syndrome">
      <data key="d0">Bernard-Soulier Syndrome</data>
      <data key="d1">condition</data>
      <data key="d2">Bernard-Soulier syndrome is a rare genetic disorder characterized by thrombocytopenia (low platelet count) and giant platelets due to mutations in the ITGB3 gene.</data>
      <data key="d3">chunk-e349119c3189688316f142a76b2f2e86</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203041</data>
