    <node id="Polymorphous Light Eruption">
      <data key="d0">Polymorphous Light Eruption</data>
      <data key="d1">data</data>
      <data key="d2">Polymorphous light eruption (PLE) or polymorphic light eruption, is a skin complaint caused by sunlight.</data>
      <data key="d3">chunk-185e181fe87408ed68fffee05c4bf2c1</data>
      <data key="d4">unknown_source</data>
