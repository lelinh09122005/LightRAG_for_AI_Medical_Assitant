    <node id="Risk Factors">
      <data key="d0">Risk Factors</data>
      <data key="d1">concept</data>
      <data key="d2">Certain risk factors increase the likelihood of developing acute otitis media, including age under 5, history of recurrent infections, and exposure to smoke.</data>
