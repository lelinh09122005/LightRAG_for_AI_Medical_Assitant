      <data key="d1">imagingfeature</data>
      <data key="d2">Hyperostosis refers to abnormal bone growth adjacent to the skull in cases of meningioma on a head CT scan.</data>
      <data key="d3">chunk-cd1410db21acf66d567e6e8a03c5bf41</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776234667</data>
