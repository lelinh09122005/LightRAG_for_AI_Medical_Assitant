    <node id="Idiopathic Sclerosing Mesenteritis">
      <data key="d0">Idiopathic Sclerosing Mesenteritis</data>
      <data key="d1">condition</data>
      <data key="d2">Idiopathic sclerosing mesenteritis is an inflammatory disease affecting the small intestine.</data>
      <data key="d3">chunk-da72dd973491937bc3732c1313c7d98b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776216615</data>
      <data key="d6" />
    </node>
    <node id="Small Intestine">
      <data key="d0">Small Intestine</data>
      <data key="d1">location</data>
      <data key="d2">The small intestine is the organ affected by idiopathic sclerosing mesenteritis.&lt;SEP&gt;The small intestine shows a similar motility response to the stomach in the gastrocolic reflex.&lt;SEP&gt;The small intestine is a portion of the human body's digestive tract.</data>
      <data key="d3">chunk-da72dd973491937bc3732c1313c7d98b&lt;SEP&gt;chunk-7ca80ee55b1b2b3e022e9995f357ddd4&lt;SEP&gt;chunk-d2d5a6443dbb30e119056feab0775e8d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776221825</data>
      <data key="d6" />
    </node>
    <node id="Chronic Pain">
      <data key="d0">Chronic Pain</data>
      <data key="d3">chunk-da72dd973491937bc3732c1313c7d98b</data>
      <data key="d2">Many people with sclerosing mesenteritis experience chronic and severe abdominal pain.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776216616</data>
      <data key="d6" />
    </node>
