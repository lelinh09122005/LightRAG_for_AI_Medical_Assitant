      <data key="d0">Immunodeficiency Disease</data>
      <data key="d1">disease</data>
      <data key="d2">Immunodeficiency disease refers to a weakened immune system that makes it difficult for the body to fight off infections.</data>
      <data key="d3">chunk-dc45fed1d8c954d3edcef5f91e52bbb2</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776220675</data>
