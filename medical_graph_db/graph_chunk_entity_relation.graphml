    <node id="Sarcoidosis">
      <data key="d0">Sarcoidosis</data>
      <data key="d1">data</data>
      <data key="d2">Sarcoidosis is an inflammatory disease characterized by the formation of non-caseating granulomas in lymph nodes and other organs.</data>
      <data key="d3">chunk-052d9f2eb36a76fdb7920ef60341853c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203610</data>
