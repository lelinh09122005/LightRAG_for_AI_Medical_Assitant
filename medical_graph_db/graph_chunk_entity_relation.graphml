    <node id="Rhinosinusitis">
      <data key="d0">Rhinosinusitis</data>
      <data key="d1">condition</data>
      <data key="d2">Patients with orbital cellulitis often have a recent history of rhinosinusitis.</data>
      <data key="d3">chunk-c675cb429137f1eae8fe9eda77046b5b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776248013</data>
      <data key="d6" />
    </node>
    <node id="Facial Insect Bite">
      <data key="d0">Facial Insect Bite</data>
      <data key="d1">event</data>
      <data key="d2">A facial insect bite may be a preceding event for orbital cellulitis.</data>
      <data key="d3">chunk-c675cb429137f1eae8fe9eda77046b5b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776248013</data>
