      <data key="d3">chunk-af76a19d7c4899519758f59183dd1222</data>
      <data key="d2">Bipolar disorders often co-occur with depressive disorders.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776232076</data>
      <data key="d6" />
    </node>
