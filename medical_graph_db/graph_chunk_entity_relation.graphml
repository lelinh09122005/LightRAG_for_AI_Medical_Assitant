    </node>
    <node id="TERT">
      <data key="d0">TERT</data>
      <data key="d1">gene</data>
      <data key="d2">TERT is a gene associated with telomere length and function, which may contribute to the pathogenesis of aplastic anemia.</data>
      <data key="d3">chunk-fcfeb24553a10cd0e61fdc71e0f554e8</data>
      <data key="d4">unknown_source</data>
