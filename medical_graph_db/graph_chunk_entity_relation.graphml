    <node id="Depressive Disorders">
      <data key="d0">Depressive Disorders</data>
      <data key="d1">mentaldisorder</data>
      <data key="d2">Depressive disorders are mental health conditions characterized by persistent feelings of sadness, hopelessness, and loss of interest.</data>
      <data key="d3">chunk-af76a19d7c4899519758f59183dd1222</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776232075</data>
