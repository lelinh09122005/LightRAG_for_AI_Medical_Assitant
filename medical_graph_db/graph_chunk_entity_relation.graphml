    <node id="Gallbladder">
      <data key="d0">Gallbladder</data>
      <data key="d1">organization</data>
      <data key="d2">The gallbladder is a small organ located under the liver that stores bile.&lt;SEP&gt;The gallbladder is a small organ that stores bile produced by the liver.</data>
      <data key="d3">chunk-af1d56bbdfcf7dcd73ada052001056e3&lt;SEP&gt;chunk-769ba65764860ea7658e8357d16cb900</data>
