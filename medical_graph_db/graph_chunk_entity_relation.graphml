      <data key="d1">location</data>
      <data key="d2">Dry summer months are typically the period when Naegleria infections occur most frequently.</data>
      <data key="d3">chunk-12f440140127265b2c2acfc6c8310641</data>
      <data key="d4">unknown_source</data>
