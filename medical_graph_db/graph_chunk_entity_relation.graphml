    </node>
    <node id="Histiocytosis">
      <data key="d0">Histiocytosis</data>
      <data key="d1">data</data>
      <data key="d2">Histiocytosis refers to a group of rare diseases involving abnormal proliferation of histiocytes (immune cells).</data>
      <data key="d3">chunk-052d9f2eb36a76fdb7920ef60341853c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203610</data>
