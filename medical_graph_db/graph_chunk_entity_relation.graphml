      <data key="d0">Post Myocardial Infarction Pericarditis</data>
      <data key="d1">condition</data>
      <data key="d2">Post myocardial infarction pericarditis, also known as Dressler's syndrome, is an inflammatory condition of the pericardium.</data>
      <data key="d3">chunk-b2df8254abbb9c5202e43d9e23991b28</data>
      <data key="d4">unknown_source</data>
