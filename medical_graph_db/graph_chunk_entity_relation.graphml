    </node>
    <node id="Mitochondrial Disease">
      <data key="d0">Mitochondrial Disease</data>
      <data key="d1">disease</data>
      <data key="d2">Mitochondrial disease is a genetic disorder that affects the mitochondria, leading to exercise intolerance.</data>
      <data key="d3">chunk-cbac6ca9c4de60d11284fef00668f6dc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776248397</data>
      <data key="d6" />
    </node>
    <node id="Neuromuscular Disease">
      <data key="d0">Neuromuscular Disease</data>
      <data key="d1">disease</data>
      <data key="d2">Neuromuscular diseases are conditions that affect the nervous system and muscles, causing exercise intolerance.</data>
      <data key="d3">chunk-cbac6ca9c4de60d11284fef00668f6dc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776248397</data>
      <data key="d6" />
    </node>
    <node id="Chronic Fatigue Syndrome">
      <data key="d0">Chronic Fatigue Syndrome</data>
      <data key="d1">symptom</data>
      <data key="d2">Nonspecific fatigue or pain syndromes such as chronic fatigue syndrome can manifest as exercise intolerance.</data>
      <data key="d3">chunk-cbac6ca9c4de60d11284fef00668f6dc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776248397</data>
      <data key="d6" />
    </node>
    <node id="Fibromyalgia">
      <data key="d0">Fibromyalgia</data>
      <data key="d1">symptom</data>
      <data key="d2">Fibromyalgia is a chronic condition characterized by widespread muscle pain, which can lead to exercise intolerance.</data>
      <data key="d3">chunk-cbac6ca9c4de60d11284fef00668f6dc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776248397</data>
      <data key="d6" />
    </node>
    <node id="Overtraining Syndrome">
      <data key="d0">Overtraining Syndrome</data>
      <data key="d1">symptom</data>
      <data key="d2">Overtraining syndrome is a condition that occurs when the body is subjected to intense physical training, leading to exercise intolerance.</data>
      <data key="d3">chunk-cbac6ca9c4de60d11284fef00668f6dc</data>
