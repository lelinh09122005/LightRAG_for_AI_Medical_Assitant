      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d2">Severe mental disturbances, including mania and psychosis, can be symptoms of Vitamin B12 deficiency.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231953</data>
      <data key="d6" />
