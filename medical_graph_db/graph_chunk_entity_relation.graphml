    <node id="Esophageal Webs/Strictures">
      <data key="d0">Esophageal Webs/Strictures</data>
      <data key="d1">physicalfinding</data>
      <data key="d2">Esophageal webs or strictures are narrow, thin membranes that can partially block the esophagus, a common finding in Plummer-Vinson syndrome.</data>
      <data key="d3">chunk-e4be7ad6187377b3faeb10739c71599a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776202280</data>
