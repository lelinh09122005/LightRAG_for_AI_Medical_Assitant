      <data key="d1">naturalobject</data>
      <data key="d2">The LAD (Left Anterior Descending) artery is one of the main coronary arteries supplying blood to the left side of the heart. A proximal LAD lesion refers to a blockage in this part of the artery.</data>
      <data key="d3">chunk-2f9dbbcfc70eb17be913a3d7973ef92e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240724</data>
      <data key="d6" />
    </node>
    <node id="Anti-anginal Medications">
      <data key="d0">Anti-anginal Medications</data>
      <data key="d1">content</data>
      <data key="d2">Patients in the CABG group required fewer anti-anginal medications compared to those who underwent PTCA.</data>
      <data key="d3">chunk-2f9dbbcfc70eb17be913a3d7973ef92e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240724</data>
      <data key="d6" />
    </node>
    <node id="Amoxicillin Dosage Schedule">
      <data key="d0">Amoxicillin Dosage Schedule</data>
      <data key="d1">dosage</data>
      <data key="d2">A 90 mg/kg/day dosage schedule for pediatric patients taking Amoxicillin.</data>
      <data key="d3">chunk-2f9dbbcfc70eb17be913a3d7973ef92e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240724</data>
      <data key="d6" />
    </node>
    <node id="Pediatric Patients With Diabetes">
      <data key="d0">Pediatric Patients With Diabetes</data>
      <data key="d1">person</data>
      <data key="d2">Patients with diabetes who undergo CABG have a better survival rate compared to those treated with PTCA.</data>
      <data key="d3">chunk-2f9dbbcfc70eb17be913a3d7973ef92e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240724</data>
      <data key="d6" />
    </node>
    <node id="Angina Symptom Severity">
      <data key="d0">Angina Symptom Severity</data>
      <data key="d1">symptom</data>
      <data key="d2">Angina symptom severity is reduced by Aspirin in patients undergoing CABG and taking fewer anti-anginal medications.</data>
      <data key="d3">chunk-2f9dbbcfc70eb17be913a3d7973ef92e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240725</data>
      <data key="d6" />
    </node>
    <node id="PTCA Procedure Complexity">
      <data key="d0">PTCA Procedure Complexity</data>
      <data key="d1">method</data>
      <data key="d2">PTCA has been found to be a simpler procedure compared to CABG for patients with certain coronary artery disease cases.</data>
      <data key="d3">chunk-2f9dbbcfc70eb17be913a3d7973ef92e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240725</data>
      <data key="d6" />
    </node>
    <node id="Revascularization Procedures">
      <data key="d0">Revascularization Procedures</data>
      <data key="d3">chunk-2f9dbbcfc70eb17be913a3d7973ef92e</data>
      <data key="d2">Patients in the CABG group required fewer revascularization procedures compared to those who underwent PTCA.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240728</data>
      <data key="d6" />
    </node>
    <node id="Angina Rate">
      <data key="d0">Angina Rate</data>
      <data key="d3">chunk-2f9dbbcfc70eb17be913a3d7973ef92e</data>
      <data key="d2">The rate of freedom from angina was better in patients who underwent CABG and took fewer anti-anginal medications.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240729</data>
      <data key="d6" />
    </node>
    <node id="Multiple Severe Lesions">
      <data key="d0">Multiple Severe Lesions</data>
      <data key="d3">chunk-2f9dbbcfc70eb17be913a3d7973ef92e</data>
      <data key="d2">The survival advantage for CABG was particularly pronounced in patients with multiple severe lesions.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240730</data>
      <data key="d6" />
    </node>
    <node id="Thrombus">
      <data key="d0">Thrombus</data>
      <data key="d1">data</data>
      <data key="d2">Thrombus, or blood clot, refers to a mass of coagulated blood that forms within a blood vessel.</data>
      <data key="d3">chunk-c2ded29f99ae36e516c58e48381779e8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240836</data>
      <data key="d6" />
    </node>
    <node id="TIMI Grade 4">
      <data key="d0">TIMI Grade 4</data>
      <data key="d1">number</data>
      <data key="d2">In TIMI (Thrombolysis In Myocardial Infarction) grading system, a score of 4 indicates the presence of a very large thrombus occupying at least two-thirds of the occluded coronary artery and having its largest dimension greater than or equal to two vessel diameters.</data>
      <data key="d3">chunk-c2ded29f99ae36e516c58e48381779e8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240836</data>
      <data key="d6" />
    </node>
    <node id="Vessel Diameter">
      <data key="d0">Vessel Diameter</data>
      <data key="d1">measure</data>
      <data key="d2">Vessel diameter is used as a reference for measuring the size of thrombi in TIMI grading system.</data>
      <data key="d3">chunk-c2ded29f99ae36e516c58e48381779e8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240836</data>
      <data key="d6" />
    </node>
    <node id="Thrombolysis In Myocardial Infarction">
      <data key="d0">Thrombolysis In Myocardial Infarction</data>
      <data key="d1">event</data>
      <data key="d2">The TIMI grading system assesses myocardial infarction treatment outcomes.</data>
      <data key="d3">chunk-c2ded29f99ae36e516c58e48381779e8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240836</data>
      <data key="d6" />
    </node>
    <node id="TIMI Grading System">
      <data key="d0">TIMI Grading System</data>
      <data key="d3">chunk-c2ded29f99ae36e516c58e48381779e8</data>
      <data key="d2">The TIMI grading system uses vessel diameter as a reference for measuring thrombus size.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776240837</data>
      <data key="d6" />
    </node>
    <node id="Hereditary Multiple Exostoses">
      <data key="d0">Hereditary Multiple Exostoses</data>
      <data key="d1">condition</data>
      <data key="d2">HME is estimated to occur in 1 in 50,000 people and affects approximately 1 in 100,000 people.</data>
      <data key="d3">chunk-2cda899614de86249768a124b9366502</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241154</data>
      <data key="d6" />
    </node>
    <node id="Cartilage-Capped Benign Bone Tumours">
      <data key="d0">Cartilage-Capped Benign Bone Tumours</data>
      <data key="d1">typeoftumour</data>
      <data key="d2">Benign bone tumours grow around areas of active bone growth.</data>
      <data key="d3">chunk-2cda899614de86249768a124b9366502</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241154</data>
      <data key="d6" />
    </node>
    <node id="Metaphysis of Long Bones">
      <data key="d0">Metaphysis of Long Bones</data>
      <data key="d1">affectedarea</data>
      <data key="d2">HME often develops in the metaphysis, a region at the end of bones where new growth occurs.</data>
      <data key="d3">chunk-2cda899614de86249768a124b9366502</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241154</data>
      <data key="d6" />
    </node>
