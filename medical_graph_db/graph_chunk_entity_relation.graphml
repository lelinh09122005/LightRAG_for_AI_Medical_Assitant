    </node>
    <node id="ESRD">
      <data key="d0">ESRD</data>
      <data key="d1">data</data>
      <data key="d2">End-stage renal disease (ESRD) is a late-stage chronic kidney disease.</data>
      <data key="d3">chunk-d9f255691d2c2b02c84652be9d8c3d51</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776206971</data>
      <data key="d6" />
    </node>
    <node id="Cirrhosis">
      <data key="d0">Cirrhosis</data>
      <data key="d1">data</data>
      <data key="d2">Cirrhosis refers to scarring of the liver, typically caused by long-standing liver disease or damage.</data>
      <data key="d3">chunk-d9f255691d2c2b02c84652be9d8c3d51</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776206971</data>
      <data key="d6" />
    </node>
    <node id="Portal Hypertension">
      <data key="d0">Portal Hypertension</data>
      <data key="d1">data</data>
      <data key="d2">Portal hypertension is increased pressure in the portal vein, typically due to liver disease.</data>
      <data key="d3">chunk-d9f255691d2c2b02c84652be9d8c3d51</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776206971</data>
      <data key="d6" />
    </node>
    <node id="Blindness">
      <data key="d0">Blindness</data>
      <data key="d3">chunk-d9f255691d2c2b02c84652be9d8c3d51</data>
      <data key="d2">Blindness often occurs in patients with Alstrom syndrome due to the disorder's effects on the eyes and visual system.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776206972</data>
      <data key="d6" />
    </node>
    <node id="Hearing Loss">
      <data key="d0">Hearing Loss</data>
      <data key="d3">chunk-d9f255691d2c2b02c84652be9d8c3d51&lt;SEP&gt;chunk-7ba9ca889a884bf086782a96a1c01374</data>
      <data key="d2">Hearing loss is a common symptom of Alstrom syndrome, affecting many patients at some point during their lifetime.&lt;SEP&gt;Hearing loss can be a consequence of untreated acute otitis media.</data>
      <data key="d1">symptom</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776210977</data>
      <data key="d6" />
    </node>
