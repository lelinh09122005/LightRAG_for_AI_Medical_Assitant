    <node id="Deficiency of Vitamin B12">
      <data key="d0">Deficiency of Vitamin B12</data>
      <data key="d1">data</data>
      <data key="d2">Vitamin B12 deficiency can cause various symptoms including tiredness, decreased mental work capacity, and irritability.</data>
      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231949</data>
      <data key="d6" />
    </node>
    <node id="Tiredness">
      <data key="d0">Tiredness</data>
      <data key="d1">symptom</data>
      <data key="d2">Tiredness is a common symptom associated with Vitamin B12 deficiency.</data>
      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231949</data>
      <data key="d6" />
    </node>
    <node id="Decreased Mental Work Capacity">
      <data key="d0">Decreased Mental Work Capacity</data>
      <data key="d1">symptom</data>
      <data key="d2">Decreased mental work capacity can affect daily functioning and productivity due to Vitamin B12 deficiency.</data>
      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231949</data>
