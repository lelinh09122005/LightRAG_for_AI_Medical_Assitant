    </node>
    <node id="Toxoplasmosis">
      <data key="d0">Toxoplasmosis</data>
      <data key="d1">data</data>
      <data key="d2">Toxoplasmosis is an infectious disease caused by the Toxoplasma gondii parasite, which can manifest as lymphadenopathy in some cases.</data>
      <data key="d3">chunk-052d9f2eb36a76fdb7920ef60341853c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203610</data>
