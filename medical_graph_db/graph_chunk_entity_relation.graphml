      <data key="d5">1776241154</data>
      <data key="d6" />
    </node>
    <node id="Limited Range of Motion at Joints">
      <data key="d0">Limited Range of Motion at Joints</data>
      <data key="d1">possibleproblem</data>
      <data key="d2">Joints affected by exostoses may have limited movement.</data>
      <data key="d3">chunk-2cda899614de86249768a124b9366502</data>
