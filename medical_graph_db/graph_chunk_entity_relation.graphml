    <node id="Protein Kinase Inhibitor">
      <data key="d0">Protein Kinase Inhibitor</data>
      <data key="d1">method</data>
      <data key="d2">A protein kinase inhibitor is a type of enzyme inhibitor which specifically blocks the action of protein kinase.</data>
      <data key="d3">chunk-e0187e7708a45e4db3589f0e72ca7402</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203679</data>
