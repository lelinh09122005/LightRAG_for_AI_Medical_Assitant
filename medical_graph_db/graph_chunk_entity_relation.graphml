    </node>
    <node id="Medication Compliance">
      <data key="d0">Medication Compliance</data>
      <data key="d1">method</data>
      <data key="d2">Medication adherence is considered for primary prevention of palpitations.</data>
      <data key="d3">chunk-5d5d870ad6493ac1d369fb7c8bf144bb</data>
