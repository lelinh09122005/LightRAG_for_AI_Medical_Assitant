      <data key="d0">Cervix</data>
      <data key="d1">location</data>
      <data key="d2">The cervix is the lower part of the uterus (womb) that opens at the top of the vagina.</data>
      <data key="d3">chunk-b74be085e56dc55429b21339be974dcb</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776247667</data>
