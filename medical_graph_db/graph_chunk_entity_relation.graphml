    <node id="Vulvovaginal Soreness">
      <data key="d0">Vulvovaginal Soreness</data>
      <data key="d1">symptom</data>
      <data key="d2">Vulvovaginal soreness is a common symptom of Candida-induced vulvovaginitis.</data>
      <data key="d3">chunk-2f889d1bbbba1e31fe8113c210d59475</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776209346</data>
      <data key="d6" />
    </node>
    <node id="Menses">
      <data key="d0">Menses</data>
      <data key="d1">event</data>
      <data key="d2">Menses refer to the periodic shedding of the uterine lining by women.</data>
