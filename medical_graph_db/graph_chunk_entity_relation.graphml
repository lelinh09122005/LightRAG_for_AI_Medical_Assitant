    <node id="Dysphagia">
      <data key="d0">Dysphagia</data>
      <data key="d1">symptom</data>
      <data key="d2">Dysphagia refers to difficulty swallowing, a primary symptom of Plummer-Vinson syndrome.</data>
      <data key="d3">chunk-e4be7ad6187377b3faeb10739c71599a</data>
      <data key="d4">unknown_source</data>
