      <data key="d13" />
    </edge>
    <edge source="Inflammation" target="COX-1 and COX-2 Enzymes">
      <data key="d7">2.0</data>
      <data key="d8">The COX pathway plays a key role in inflammatory responses.&lt;SEP&gt;Aspirin works by irreversibly inhibiting these enzymes, reducing inflammation.</data>
      <data key="d9">reduction,therapeutic effect,therapeutic effect reduction</data>
      <data key="d10">chunk-a45c0433e861eaa94dbda4172985c8d7&lt;SEP&gt;chunk-c6c01ebde56aad2ac664ce27bcf95cd5</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776214244</data>
      <data key="d13" />
    </edge>
    <edge source="Inflammation" target="Tonsillitis">
      <data key="d7">1.0</data>
      <data key="d8">Tonsillitis refers to inflammation of the tonsils, often caused by infection or allergy.</data>
      <data key="d9">cause,reason</data>
      <data key="d10">chunk-073142c11014525a0c579f8afe5d210b</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776216218</data>
      <data key="d13" />
    </edge>
    <edge source="Inflammation" target="USG">
      <data key="d7">1.0</data>
