      <data key="d4">unknown_source</data>
      <data key="d5">1776241156</data>
      <data key="d6" />
    </node>
    <node id="Lung Cancer">
      <data key="d0">Lung Cancer</data>
      <data key="d1">data</data>
      <data key="d2">Lung cancer is a common type of cancer in the world, primarily linked to smoking.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241244</data>
      <data key="d6" />
    </node>
    <node id="Cigarette Smoking">
      <data key="d0">Cigarette Smoking</data>
      <data key="d1">artifact</data>
      <data key="d2">Cigarette smoking is the primary cause of most lung cancers.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241244</data>
      <data key="d6" />
    </node>
    <node id="Pollution">
      <data key="d0">Pollution</data>
      <data key="d1">naturalobject</data>
      <data key="d2">High levels of pollution contribute to an increased risk of developing lung cancer.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241244</data>
      <data key="d6" />
    </node>
    <node id="Asbestos Exposure">
      <data key="d0">Asbestos Exposure</data>
      <data key="d1">naturalobject</data>
      <data key="d2">Another known factor linked to lung cancer development is asbestos exposure.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241244</data>
      <data key="d6" />
    </node>
    <node id="Small Cell Lung Carcinoma">
      <data key="d0">Small Cell Lung Carcinoma</data>
      <data key="d1">data</data>
      <data key="d2">According to pathology, lung cancer can be classified into small cell lung carcinoma and non-small cell lung carcinoma.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241244</data>
      <data key="d6" />
    </node>
    <node id="Non-Small Cell Lung Carcinoma">
      <data key="d0">Non-Small Cell Lung Carcinoma</data>
      <data key="d1">data</data>
      <data key="d2">It is further divided based on its characteristics.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241244</data>
      <data key="d6" />
    </node>
    <node id="Cough">
      <data key="d0">Cough</data>
      <data key="d1">symptom</data>
      <data key="d2">A persistent cough, especially one that does not go away, is an early symptom of lung cancer.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241244</data>
      <data key="d6" />
    </node>
    <node id="Constant Chest Pain">
      <data key="d0">Constant Chest Pain</data>
      <data key="d1">symptom</data>
      <data key="d2">Chronic chest pain often accompanies the disease.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241244</data>
      <data key="d6" />
    </node>
    <node id="Blood Coughing">
      <data key="d0">Blood Coughing</data>
      <data key="d1">symptom</data>
      <data key="d2">Additionally, coughing up blood is another symptom to look out for in lung cancer cases.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241244</data>
      <data key="d6" />
    </node>
    <node id="Hoarseness">
      <data key="d0">Hoarseness</data>
      <data key="d1">symptom</data>
      <data key="d2">Hoarseness can also occur due to the progression of the disease.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241244</data>
      <data key="d6" />
    </node>
    <node id="Pneumonia and Bronchitis Problems">
      <data key="d0">Pneumonia and Bronchitis Problems</data>
      <data key="d1">symptom</data>
      <data key="d2">Recurring pneumonia or bronchitis issues are notable signs of lung cancer.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241244</data>
      <data key="d6" />
    </node>
    <node id="Neck Swelling">
      <data key="d0">Neck Swelling</data>
      <data key="d1">symptom</data>
      <data key="d2">Swelling in the neck and face can signal that the tumor is spreading to nearby tissues.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241244</data>
      <data key="d6" />
    </node>
    <node id="Weight Loss">
      <data key="d0">Weight Loss</data>
      <data key="d1">data</data>
      <data key="d2">Weight loss often occurs due to a reduced appetite caused by the disease.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241245</data>
      <data key="d6" />
    </node>
    <node id="Fatigue">
      <data key="d0">Fatigue</data>
      <data key="d1">symptom</data>
      <data key="d2">Tiredness is another common symptom experienced by patients with lung cancer.</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241245</data>
      <data key="d6" />
    </node>
    <node id="Radiation Exposure">
      <data key="d0">Radiation Exposure</data>
      <data key="d3">chunk-dbe7a4df275280a24a14fa22f341095f</data>
      <data key="d2">Exposure to high levels of pollution can increase the likelihood of radiation exposure and subsequent lung cancer development.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241330</data>
      <data key="d6" />
    </node>
    <node id="Ileus">
      <data key="d0">Ileus</data>
      <data key="d1">condition</data>
      <data key="d2">Ileus is a medical condition characterized by a blockage or slowed movement in the intestines.</data>
      <data key="d3">chunk-14b816e92bef56efc847f553621ed0a5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241477</data>
      <data key="d6" />
    </node>
    <node id="Early Mobilization">
      <data key="d0">Early Mobilization</data>
      <data key="d1">method</data>
      <data key="d2">Early mobilization, including physical therapy and exercise, can help prevent ileus.</data>
      <data key="d3">chunk-14b816e92bef56efc847f553621ed0a5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241477</data>
      <data key="d6" />
    </node>
    <node id="Ryle's Tube">
      <data key="d0">Ryle's Tube</data>
      <data key="d1">device</data>
      <data key="d2">A nasogastric tube, such as Ryle's tube, should be avoided to minimize the risk of developing ileus.</data>
      <data key="d3">chunk-14b816e92bef56efc847f553621ed0a5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241477</data>
      <data key="d6" />
    </node>
    <node id="High Carbohydrate Solution">
      <data key="d0">High Carbohydrate Solution</data>
      <data key="d1">content</data>
      <data key="d2">A high carbohydrate solid or liquid solution can aid in preventing ileus when consumed prior to surgery.</data>
      <data key="d3">chunk-14b816e92bef56efc847f553621ed0a5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241477</data>
      <data key="d6" />
    </node>
    <node id="Parenteral Fluids">
      <data key="d0">Parenteral Fluids</data>
      <data key="d1">device</data>
      <data key="d2">Parenteral fluids should be limited to minimize the risk of developing ileus.</data>
      <data key="d3">chunk-14b816e92bef56efc847f553621ed0a5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241477</data>
      <data key="d6" />
    </node>
    <node id="Minimally Invasive Surgical Method">
      <data key="d0">Minimally Invasive Surgical Method</data>
      <data key="d1">method</data>
      <data key="d2">A minimally invasive surgical method is used to treat ileus, reducing the risk of complications.</data>
      <data key="d3">chunk-14b816e92bef56efc847f553621ed0a5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241477</data>
      <data key="d6" />
    </node>
    <node id="Gastric Emptying">
      <data key="d0">Gastric Emptying</data>
      <data key="d1">process</data>
      <data key="d2">Gastric emptying is the process by which food moves from the stomach into the small intestine for further digestion.</data>
      <data key="d3">chunk-14b816e92bef56efc847f553621ed0a5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241477</data>
      <data key="d6" />
    </node>
    <node id="Physical Therapy">
      <data key="d0">Physical Therapy</data>
      <data key="d1">method</data>
      <data key="d2">Physical therapy, including exercise and physical rehabilitation, helps prevent ileus.</data>
      <data key="d3">chunk-14b816e92bef56efc847f553621ed0a5</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241477</data>
      <data key="d6" />
    </node>
    <node id="Nasogastric Tube">
      <data key="d0">Nasogastric Tube</data>
      <data key="d1">device</data>
