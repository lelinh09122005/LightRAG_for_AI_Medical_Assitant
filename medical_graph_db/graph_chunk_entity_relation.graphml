      <data key="d1">location</data>
      <data key="d2">The sinoatrial node is a small group of specialized cardiac cells located near the junction between the right and left atria.</data>
      <data key="d3">chunk-0d9df8319256ab3c418f8c73ac00fad8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776215601</data>
