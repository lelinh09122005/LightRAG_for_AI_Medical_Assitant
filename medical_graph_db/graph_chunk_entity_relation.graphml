    <node id="Urethral Cancer">
      <data key="d0">Urethral Cancer</data>
      <data key="d1">disease</data>
      <data key="d2">Urethral cancer is a condition affecting the urethra, which carries urine from the bladder.</data>
      <data key="d3">chunk-1a63d042ddd8edeccd869d1b75dceedf</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231731</data>
