    </node>
    <node id="Transposition of the Great Arteries (TGA)">
      <data key="d0">Transposition of the Great Arteries (TGA)</data>
      <data key="d1">data</data>
      <data key="d2">A general term which may refer to both l-TGA and d-TGA, as well as other types of transposition.</data>
      <data key="d3">chunk-8e89c93cc380a668363623c506d07964</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776220972</data>
