    <node id="Bladder">
      <data key="d0">Bladder</data>
      <data key="d1">location</data>
      <data key="d2">The bladder is a hollow organ that stores urine.</data>
      <data key="d3">chunk-1a63d042ddd8edeccd869d1b75dceedf</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231732</data>
