      <data key="d3">chunk-af76a19d7c4899519758f59183dd1222</data>
      <data key="d2">The "catatonia specifier" is used to indicate that symptoms meet criteria for catatonia during the course of another mental disorder.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776232077</data>
