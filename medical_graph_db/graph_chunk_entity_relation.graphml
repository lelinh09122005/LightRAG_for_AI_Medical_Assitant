    <node id="Cat-Scratch Disease">
      <data key="d0">Cat-Scratch Disease</data>
      <data key="d1">data</data>
      <data key="d2">Cat-scratch disease is a rare bacterial infection caused by Bartonella henselae, often leading to lymphadenopathy.</data>
      <data key="d3">chunk-052d9f2eb36a76fdb7920ef60341853c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203610</data>
