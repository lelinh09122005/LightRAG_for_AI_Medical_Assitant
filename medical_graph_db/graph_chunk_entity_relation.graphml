    <node id="May-Hegglin Syndrome">
      <data key="d0">May-Hegglin Syndrome</data>
      <data key="d1">condition</data>
      <data key="d2">May-Heglin syndrome is a rare genetic disorder affecting both males and females, characterized by thrombocytopenia (low platelet count), giant platelets, and renal tubular acidosis due to mutations in the EPAS1 gene.</data>
      <data key="d3">chunk-e349119c3189688316f142a76b2f2e86</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203041</data>
