      <data key="d0">Colonoscopy</data>
      <data key="d1">medicalprocedure</data>
      <data key="d2">Colonoscopy is a procedure used to screen for and diagnose colon and rectal cancers in patients with IBD.</data>
      <data key="d3">chunk-491c0761387cab9f81178653066edcbc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776204356</data>
