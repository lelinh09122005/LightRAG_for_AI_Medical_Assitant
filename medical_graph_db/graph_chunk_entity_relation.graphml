    <node id="Atrioventricular Node">
      <data key="d0">Atrioventricular Node</data>
      <data key="d1">location</data>
      <data key="d2">The atrioventricular node (AVN) is a critical component of the heart's electrical conduction system.</data>
      <data key="d3">chunk-b8f8e8de9e94ff3a0fb159812013b14d</data>
      <data key="d4">unknown_source</data>
