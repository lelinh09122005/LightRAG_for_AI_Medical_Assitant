    <node id="Trypanosoma cruzi">
      <data key="d0">Trypanosoma cruzi</data>
      <data key="d1">pathogen</data>
      <data key="d2">Trypanosoma cruzi is the causative agent of Chagas disease, transmitted primarily through the bites of infected triatomine bugs, also known as kissing bugs.</data>
      <data key="d3">chunk-42e608f979ae406dce55ee3db11f5b0e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776225962</data>
