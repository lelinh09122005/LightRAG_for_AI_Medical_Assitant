      <data key="d0">Pain or Numbness from Nerve Compression</data>
      <data key="d1">possibleproblem</data>
      <data key="d2">Pain or numbness can result from nerve compression caused by the exostoses.</data>
      <data key="d3">chunk-2cda899614de86249768a124b9366502</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241154</data>
      <data key="d6" />
    </node>
    <node id="Vascular Compromise">
      <data key="d0">Vascular Compromise</data>
      <data key="d1">possibleproblem</data>
      <data key="d2">Exostoses can compromise blood vessels, leading to potential complications.</data>
      <data key="d3">chunk-2cda899614de86249768a124b9366502</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241154</data>
      <data key="d6" />
    </node>
    <node id="Inequality of Limb Length">
      <data key="d0">Inequality of Limb Length</data>
      <data key="d1">possibleproblem</data>
      <data key="d2">Unequal limb length is a possible consequence of HME.</data>
      <data key="d3">chunk-2cda899614de86249768a124b9366502</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776241154</data>
