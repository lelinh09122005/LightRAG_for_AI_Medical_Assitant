    </node>
    <node id="Junctional Tachycardia">
      <data key="d0">Junctional Tachycardia</data>
      <data key="d1">event</data>
      <data key="d2">Junctional tachycardia is a type of rapid heart rate originating from the AVN or its surrounding tissues.</data>
      <data key="d3">chunk-b8f8e8de9e94ff3a0fb159812013b14d</data>
      <data key="d4">unknown_source</data>
