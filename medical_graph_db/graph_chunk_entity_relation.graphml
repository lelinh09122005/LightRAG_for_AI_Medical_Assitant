    <node id="Grape-like Vaginal Tissue">
      <data key="d0">Grape-like Vaginal Tissue</data>
      <data key="d1">data</data>
      <data key="d2">A grape-like vaginal tissue is a classic presentation of sarcoma botryoides, indicating a high risk for diagnosis and treatment.</data>
      <data key="d3">chunk-9726252f8d24a278bed590bba4e8f9bf</data>
      <data key="d4">unknown_source</data>
