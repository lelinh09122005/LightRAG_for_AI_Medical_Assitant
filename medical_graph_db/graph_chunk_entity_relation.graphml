    <node id="Electrical Conduction System">
      <data key="d0">Electrical Conduction System</data>
      <data key="d1">concept</data>
      <data key="d2">The electrical conduction system of the heart refers to the network of specialized cardiac tissues responsible for coordinated contraction.</data>
      <data key="d3">chunk-b8f8e8de9e94ff3a0fb159812013b14d</data>
      <data key="d4">unknown_source</data>
