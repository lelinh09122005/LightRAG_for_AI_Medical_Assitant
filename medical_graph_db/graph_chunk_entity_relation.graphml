    </edge>
    <edge source="Catatonia" target="Neurodevelopmental Disorder">
      <data key="d7">1.0</data>
      <data key="d8">When symptoms meet criteria for catatonia during the course of a neurodevelopmental disorder, it may be specified as such.</data>
