    <node id="Polycythemia">
      <data key="d0">Polycythemia</data>
      <data key="d1">condition</data>
      <data key="d2">Polycythemia is a medical condition characterized by an increase in the total number of red blood cells in the body.</data>
      <data key="d3">chunk-27ddd07c03c4a22cb59ce2d699b0d3f2</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776247930</data>
      <data key="d6" />
    </node>
    <node id="Bone Marrow">
      <data key="d0">Bone Marrow</data>
      <data key="d1">location</data>
      <data key="d2">The bone marrow plays a primary role in the overproduction of red blood cells in polycythemia.</data>
      <data key="d3">chunk-27ddd07c03c4a22cb59ce2d699b0d3f2</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776247930</data>
      <data key="d6" />
    </node>
    <node id="Oxygen Levels">
      <data key="d0">Oxygen Levels</data>
      <data key="d1">concept</data>
      <data key="d2">Polycythemia can be caused by chronically low oxygen levels in the body.</data>
      <data key="d3">chunk-27ddd07c03c4a22cb59ce2d699b0d3f2</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776247930</data>
      <data key="d6" />
    </node>
    <node id="Malignancy">
      <data key="d0">Malignancy</data>
      <data key="d1">cause</data>
      <data key="d2">In rare cases, polycythemia may be caused by a malignancy (cancer).</data>
      <data key="d3">chunk-27ddd07c03c4a22cb59ce2d699b0d3f2</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776247930</data>
      <data key="d6" />
    </node>
    <node id="Primary Process">
      <data key="d0">Primary Process</data>
      <data key="d1">cause</data>
      <data key="d2">A primary process in the bone marrow can lead to polycythemia.</data>
      <data key="d3">chunk-27ddd07c03c4a22cb59ce2d699b0d3f2</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776247930</data>
      <data key="d6" />
    </node>
    <node id="Red Blood Cell Production">
      <data key="d0">Red Blood Cell Production</data>
      <data key="d3">chunk-27ddd07c03c4a22cb59ce2d699b0d3f2</data>
      <data key="d2">The bone marrow is responsible for producing the majority of red blood cells in the body.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776247931</data>
      <data key="d6" />
    </node>
    <node id="Hypoxia">
