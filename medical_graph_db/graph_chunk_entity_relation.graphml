    <node id="Meningioma">
      <data key="d0">Meningioma</data>
      <data key="d1">neurologicalcondition</data>
      <data key="d2">Meningioma is a type of tumor that grows on the meninges, which are the protective membranes surrounding the brain and spinal cord.</data>
