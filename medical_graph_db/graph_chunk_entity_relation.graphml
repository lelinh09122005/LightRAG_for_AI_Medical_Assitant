    <node id="Vitamin B12">
      <data key="d0">Vitamin B12</data>
      <data key="d1">data</data>
      <data key="d2">Vitamin B12 is a nutrient crucial for energy production, nerve function, and DNA synthesis.</data>
      <data key="d3">chunk-64464fe427daf4856c5208850d191d79</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231949</data>
