      <data key="d12">1776199283</data>
      <data key="d13" />
    </edge>
    <edge source="Portal Vein" target="Inflammation">
      <data key="d7">1.0</data>
      <data key="d8">The portal vein is the site of inflammation in pylephlebitis.</data>
      <data key="d9">affected area,target location</data>
