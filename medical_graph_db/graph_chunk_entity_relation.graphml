    <node id="Infectious Agent">
      <data key="d0">Infectious Agent</data>
      <data key="d1">concept</data>
      <data key="d2">The infectious agent responsible for causing acute otis media is typically Streptococcus pneumoniae, Haemophilus influenzae, or Moraxella catarrhalis.</data>
      <data key="d3">chunk-17717aab6acc128a83824d9e8317ea4f</data>
