    <node id="Alcohol Abuse">
      <data key="d0">Alcohol Abuse</data>
      <data key="d1">triggers</data>
      <data key="d2">Excessive alcohol consumption is a trigger that can lead to or worsen palpitations.</data>
      <data key="d3">chunk-5d5d870ad6493ac1d369fb7c8bf144bb</data>
