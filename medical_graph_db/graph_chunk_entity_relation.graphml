    <node id="Edema">
      <data key="d0">Edema</data>
      <data key="d1">sideeffect</data>
      <data key="d2">Edema is an imaging feature that can be present on a head CT scan for meningioma.&lt;SEP&gt;Edema is a common physical examination finding in patients with tumor lysis syndrome, characterized by swelling of the body's tissues.</data>
      <data key="d3">chunk-cd1410db21acf66d567e6e8a03c5bf41&lt;SEP&gt;chunk-49ab824223b2cb236dc5551487939dab</data>
