      <data key="d3">chunk-350836c0cbd5f38144bfd64dc2e11cd0</data>
      <data key="d2">Hemangiomas are characterized by specific clinical features that aid in their diagnosis.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236146</data>
      <data key="d6" />
    </node>
    <node id="Sheehan's Syndrome">
      <data key="d0">Sheehan's Syndrome</data>
      <data key="d1">condition</data>
      <data key="d2">Sheehan's syndrome is a condition caused by partial or panhypopituitarism.</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236245</data>
      <data key="d6" />
    </node>
    <node id="Partial or Panhypopituitarism">
      <data key="d0">Partial or Panhypopituitarism</data>
      <data key="d1">disease</data>
      <data key="d2">Partial or panhypopituitarism refers to a spectrum of disorders involving one or more pituitary hormones deficiencies, including Sheehan's syndrome.</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236245</data>
      <data key="d6" />
    </node>
    <node id="Hypotension">
      <data key="d0">Hypotension</data>
      <data key="d1">sideeffect</data>
      <data key="d2">Hyponatremia is a common side effect of the condition that can lead to hypotension in patients with Sheehan's syndrome.</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236245</data>
      <data key="d6" />
    </node>
    <node id="Low Fasting Plasma Glucose">
      <data key="d0">Low Fasting Plasma Glucose</data>
      <data key="d1">medicalprocedure</data>
      <data key="d2">Decreased levels of glucose in the blood are observed in patients suffering from Sheehan's Syndrome.</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236245</data>
      <data key="d6" />
    </node>
    <node id="Anterior Pituitary Hormones">
      <data key="d0">Anterior Pituitary Hormones</data>
      <data key="d1">content</data>
      <data key="d2">The anterior pituitary gland releases several vital hormones that regulate multiple bodily functions. However, it is affected by Sheehan's Syndrome and does not function properly, which affects hormone levels.</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236245</data>
      <data key="d6" />
    </node>
    <node id="Gonadotropin Response">
      <data key="d0">Gonadotropin Response</data>
      <data key="d1">method</data>
      <data key="d2">A gonadotropin response test assesses the function of the pituitary gland and determines its ability to release specific hormones, like estradiol. In the case of Sheehan's syndrome, this test reveals an inadequate response.</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236245</data>
      <data key="d6" />
    </node>
    <node id="Postpartum Hemorrhage">
      <data key="d0">Postpartum Hemorrhage</data>
      <data key="d1">condition</data>
      <data key="d2">Sheehan's syndrome may result in postpartum hemorrhage due to pituitary hormone deficiencies.</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236245</data>
      <data key="d6" />
    </node>
    <node id="Adrenal Insufficiency">
      <data key="d0">Adrenal Insufficiency</data>
      <data key="d1">condition</data>
      <data key="d2">Another potential consequence of Sheehan's syndrome, this condition can lead to decreased cortisol production.</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236245</data>
      <data key="d6" />
    </node>
    <node id="Thyroid Hormone Deficiency">
      <data key="d0">Thyroid Hormone Deficiency</data>
      <data key="d1">condition</data>
      <data key="d2">Sheehan's syndrome can also lead to decreased production of thyroid hormones, which regulate metabolism.</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236245</data>
      <data key="d6" />
    </node>
    <node id="Cushing's Syndrome">
      <data key="d0">Cushing's Syndrome</data>
      <data key="d1">condition</data>
      <data key="d2">A different hormonal disorder caused by excess glucocorticoids, which can be treated with medication.</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236246</data>
      <data key="d6" />
    </node>
    <node id="Hyperaldosteronism">
      <data key="d0">Hyperaldosteronism</data>
      <data key="d1">condition</data>
      <data key="d2">A rare endocrine disorder that affects the adrenal glands, leading to excessive aldosterone production.</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236246</data>
      <data key="d6" />
    </node>
    <node id="Primary Hypothyroidism">
      <data key="d0">Primary Hypothyroidism</data>
      <data key="d1">condition</data>
      <data key="d2">Another potential consequence of Sheehan's syndrome, this condition can lead to decreased production of thyroid hormones.</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236246</data>
      <data key="d6" />
    </node>
    <node id="Addison's Disease">
      <data key="d0">Addison's Disease</data>
      <data key="d1">condition</data>
      <data key="d2">A rare endocrine disorder characterized by the insufficient production of cortisol and aldosterone.</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236246</data>
      <data key="d6" />
    </node>
    <node id="Glucocorticoid Exposure">
      <data key="d0">Glucocorticoid Exposure</data>
      <data key="d3">chunk-a90bf38c850a0d10b54a8c7b210bf24c</data>
      <data key="d2">increased risk of bone fractures and density loss due to prolonged steroid use</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776236248</data>
      <data key="d6" />
    </node>
