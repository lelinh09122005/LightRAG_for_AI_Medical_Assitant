    </node>
    <node id="Precordium">
      <data key="d0">Precordium</data>
      <data key="d1">location</data>
      <data key="d2">The palpitations may refer to the area around the heart, specifically the precordium.</data>
      <data key="d3">chunk-e521741147e08defca5beb7c20e86d2a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776215662</data>
