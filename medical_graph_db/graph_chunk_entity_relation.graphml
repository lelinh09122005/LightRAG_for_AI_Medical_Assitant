    <node id="Neoplastic Growth">
      <data key="d0">Neoplastic Growth</data>
      <data key="d1">concept</data>
      <data key="d2">Neoplastic growth refers to uncontrolled cell proliferation in tissues or organs, often associated with cancer.</data>
      <data key="d3">chunk-b5c6f77b16e16e44d387190c97da1df2</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776211798</data>
