    <node id="Congestive Heart Failure">
      <data key="d0">Congestive Heart Failure</data>
      <data key="d1">condition</data>
      <data key="d2">Congestive heart failure is the condition being treated by Lisinopril.&lt;SEP&gt;Congestive heart failure is a medical condition characterized by impaired fluid balance within the body.</data>
      <data key="d3">chunk-331beb4d681443473668b1b86bc0a556&lt;SEP&gt;chunk-d9f255691d2c2b02c84652be9d8c3d51&lt;SEP&gt;chunk-be0afdf0753c12d1860d48df1a690238</data>
