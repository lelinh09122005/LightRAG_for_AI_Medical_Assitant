    <node id="Sinoatrial Node">
      <data key="d0">Sinoatrial Node</data>
      <data key="d1">location</data>
      <data key="d2">The sinoatrial node (SA node) is responsible for generating an escape rhythm when it fails or slows down.</data>
      <data key="d3">chunk-b8f8e8de9e94ff3a0fb159812013b14d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776225527</data>
