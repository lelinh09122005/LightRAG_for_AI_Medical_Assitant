    <node id="Myometrium">
      <data key="d0">Myometrium</data>
      <data key="d1">naturalobject</data>
      <data key="d2">The myometrium is the muscular layer of the uterus that can be affected by sarcoma botryoides.</data>
      <data key="d3">chunk-9726252f8d24a278bed590bba4e8f9bf</data>
      <data key="d4">unknown_source</data>
