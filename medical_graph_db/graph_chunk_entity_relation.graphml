    <node id="STAT3">
      <data key="d0">STAT3</data>
      <data key="d1">gene</data>
      <data key="d2">STAT3 is another gene linked to aplastic anemia, involved in cell signaling pathways.</data>
      <data key="d3">chunk-fcfeb24553a10cd0e61fdc71e0f554e8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776204149</data>
