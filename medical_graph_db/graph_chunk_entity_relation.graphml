    <node id="Discomfort">
      <data key="d0">Discomfort</data>
      <data key="d1">symptom</data>
      <data key="d2">Discomfort is a common symptom experienced by individuals with constipation.</data>
      <data key="d3">chunk-58320e3f9e2aeb800e533ad8fd0fa94e</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776199943</data>
