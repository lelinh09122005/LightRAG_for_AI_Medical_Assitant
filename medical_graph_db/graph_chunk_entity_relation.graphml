    <node id="PR Interval">
      <data key="d0">PR Interval</data>
      <data key="d1">concept</data>
      <data key="d2">The PR interval refers to the time taken for an electrical impulse to travel from the atria to the ventricles in the heart.</data>
      <data key="d3">chunk-0d9df8319256ab3c418f8c73ac00fad8</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776215601</data>
