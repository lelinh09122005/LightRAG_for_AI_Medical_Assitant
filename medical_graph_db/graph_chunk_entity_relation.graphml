      <data key="d5">1776204356</data>
      <data key="d6" />
    </node>
    <node id="Routine Surveillance">
      <data key="d0">Routine Surveillance</data>
      <data key="d1">medicalprocedure</data>
      <data key="d2">Colonoscopy is a procedure used to screen for and diagnose colon and rectal cancers in patients with IBD, and also serves as a means of monitoring the general population for colorectal cancer.</data>
      <data key="d3">chunk-491c0761387cab9f81178653066edcbc</data>
