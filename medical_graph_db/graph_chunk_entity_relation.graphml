      <data key="d3">chunk-da72dd973491937bc3732c1313c7d98b</data>
      <data key="d2">Sclerosing mesenteritis is identified through histopathological examination showing fat necrosis and fibrosis.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776216618</data>
      <data key="d6" />
    </node>
    <node id="Solitary Mass">
      <data key="d0">Solitary Mass</data>
      <data key="d3">chunk-da72dd973491937bc3732c1313c7d98b</data>
      <data key="d2">The presence of a solitary mass in the mesentery may indicate sclerosing mesenteritis.</data>
      <data key="d1">UNKNOWN</data>
