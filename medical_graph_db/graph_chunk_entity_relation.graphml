    <node id="Metabolic Syndrome">
      <data key="d0">Metabolic Syndrome</data>
      <data key="d1">disease</data>
      <data key="d2">Metabolic syndrome refers to a cluster of conditions including insulin resistance, hypertension, and dyslipidemia that increase the risk of developing type 2 diabetes and cardiovascular disease.&lt;SEP&gt;Metabolic syndrome is a cluster of conditions that increase the risk of developing type 2 diabetes and cardiovascular disease.</data>
      <data key="d3">chunk-14491e922b3c111ccfd99b482d34948b&lt;SEP&gt;chunk-05a062c31232f7d983bd96c0052adfc7</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776226350</data>
      <data key="d6" />
    </node>
    <node id="Insulin Resistance/Hyperinsulinemia">
      <data key="d0">Insulin Resistance/Hyperinsulinemia</data>
      <data key="d1">cause</data>
      <data key="d2">Insulin resistance and hyperinsulinemia are common underlying causes of metabolic syndrome.</data>
      <data key="d3">chunk-14491e922b3c111ccfd99b482d34948b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776212197</data>
