    <node id="Pallor">
      <data key="d0">Pallor</data>
      <data key="d1">physicalfinding</data>
      <data key="d2">A lack of skin pigmentation or a pale appearance, which can be an indicator of poor circulation, fatigue, or chronic illness such as liver failure.&lt;SEP&gt;Pallor is a pale complexion, often observed in patients with Plummer-Vinson syndrome.</data>
      <data key="d3">chunk-a45c0433e861eaa94dbda4172985c8d7&lt;SEP&gt;chunk-e4be7ad6187377b3faeb10739c71599a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776202280</data>
      <data key="d6" />
    </node>
    <node id="Jaundice">
      <data key="d0">Jaundice</data>
      <data key="d1">disease</data>
      <data key="d2">A yellowing of the skin and eyes due to high bilirubin levels in the blood, indicative of liver dysfunction.&lt;SEP&gt;Jaundice is a condition characterized by high levels of bilirubin in the blood, often seen in newborns.</data>
      <data key="d3">chunk-a45c0433e861eaa94dbda4172985c8d7&lt;SEP&gt;chunk-3cabd69644d8352c70635652f93fbfbb</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776217255</data>
      <data key="d6" />
    </node>
    <node id="Plantar and palmar erythema">
      <data key="d0">Plantar and palmar erythema</data>
      <data key="d1">sideeffect</data>
      <data key="d2">A condition characterized by redness on the soles of the feet or palms of the hands, often seen as a manifestation of abnormal liver function.</data>
      <data key="d3">chunk-a45c0433e861eaa94dbda4172985c8d7</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776201120</data>
