    <node id="Median Sternotomy Wires">
      <data key="d0">Median Sternotomy Wires</data>
      <data key="d1">anatomicalstructure</data>
      <data key="d2">Median sternotomy wires are structures used to support the sternum during surgical procedures.</data>
      <data key="d3">chunk-edd1b5df83b2e724f45910a954f75413</data>
