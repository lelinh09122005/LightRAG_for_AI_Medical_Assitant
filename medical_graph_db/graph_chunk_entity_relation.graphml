    <node id="Calcium Metabolism">
      <data key="d0">Calcium Metabolism</data>
      <data key="d1">concept</data>
      <data key="d2">Abnormal calcium metabolism in the sarcoplasmic reticulum is thought to cause enhanced automaticity in the atrioventricular node.</data>
      <data key="d3">chunk-b8f8e8de9e94ff3a0fb159812013b14d</data>
      <data key="d4">unknown_source</data>
