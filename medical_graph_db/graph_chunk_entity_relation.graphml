    <node id="Ocular Movements">
      <data key="d0">Ocular Movements</data>
      <data key="d1">physicalexamination</data>
      <data key="d2">Patient movements may be painful or restricted in orbital cellulitis.</data>
      <data key="d3">chunk-c675cb429137f1eae8fe9eda77046b5b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776248013</data>
