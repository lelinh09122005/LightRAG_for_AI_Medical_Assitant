      <data key="d1">symptom</data>
      <data key="d2">Swelling in the groin area is another possible symptom of urethral cancer.</data>
      <data key="d3">chunk-1a63d042ddd8edeccd869d1b75dceedf</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776231732</data>
