    <edge source="Acrodermatitis Chronica Atrophicans" target="Constitutional Symptoms">
      <data key="d7">1.0</data>
      <data key="d8">Constitutional symptoms such as fever and fatigue may accompany acrodermatitis chronica atrophicans.</data>
      <data key="d9">manifestations,symptomatology</data>
      <data key="d10">chunk-58ce513efff4e4279006c76309bbe13e</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776197736</data>
      <data key="d13" />
    </edge>
    <edge source="Acrodermatitis Chronica Atrophicans" target="Fever and Fatigue">
      <data key="d7">1.0</data>
      <data key="d8">Fever and fatigue are common constitutional symptoms in patients with acrodermatitis chronica atrophicans.</data>
      <data key="d9">manifestations,symptomatology</data>
      <data key="d10">chunk-58ce513efff4e4279006c76309bbe13e</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776197737</data>
      <data key="d13" />
    </edge>
    <edge source="Acrodermatitis Chronica Atrophicans" target="Lower Limb Involvement">
      <data key="d7">1.0</data>
      <data key="d8">The lower limb is more commonly involved than the upper limb in acrodermatitis chronica atrophicans.</data>
      <data key="d9">affected area,skin involvement</data>
      <data key="d10">chunk-58ce513efff4e4279006c76309bbe13e</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776197737</data>
      <data key="d13" />
    </edge>
    <edge source="Acrodermatitis Chronica Atrophicans" target="Upper Limb Involvement">
      <data key="d7">1.0</data>
      <data key="d8">The upper limb is less commonly involved than the lower limb in acrodermatitis chronica atrophicans.</data>
      <data key="d9">affected area,skin involvement</data>
      <data key="d10">chunk-58ce513efff4e4279006c76309bbe13e</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776197738</data>
      <data key="d13" />
    </edge>
    <edge source="Acrodermatitis Chronica Atrophicans" target="Bilateral Acral Involvement">
      <data key="d7">1.0</data>
      <data key="d8">A significant proportion of patients with acrodermatitis chronica atrophicans experience bilateral acral involvement.</data>
      <data key="d9">affected area,skin involvement</data>
      <data key="d10">chunk-58ce513efff4e4279006c76309bbe13e</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776197738</data>
      <data key="d13" />
    </edge>
    <edge source="Acrodermatitis Chronica Atrophicans" target="Unilateral Skin Involvement">
      <data key="d7">1.0</data>
      <data key="d8">Only a small fraction of patients with acrodermatitis chronica atrophicans have unilateral skin involvement.</data>
      <data key="d9">affected area,skin involvement</data>
      <data key="d10">chunk-58ce513efff4e4279006c76309bbe13e</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776197739</data>
      <data key="d13" />
    </edge>
    <edge source="Acrodermatitis Chronica Atrophicans" target="Nodule and Arthritis">
      <data key="d7">1.0</data>
      <data key="d8">A small proportion of patients experience symptoms such as nodules, arthritis, itching, muscle atrophy, joint deformities, and paresis.</data>
      <data key="d9">manifestations,symptomatology</data>
      <data key="d10">chunk-58ce513efff4e4279006c76309bbe13e</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776197739</data>
      <data key="d13" />
    </edge>
    <edge source="Acrodermatitis Chronica Atrophicans" target="Muscle Atrophy">
      <data key="d7">1.0</data>
      <data key="d8">Muscle atrophy is a rare symptom of acrodermatitis chronica atrophicans.</data>
      <data key="d9">manifestations,symptomatology</data>
      <data key="d10">chunk-58ce513efff4e4279006c76309bbe13e</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776197740</data>
      <data key="d13" />
    </edge>
    <edge source="Acrodermatitis Chronica Atrophicans" target="Paresis">
      <data key="d7">1.0</data>
      <data key="d8">Paresis (weakness) is a rare symptom associated with acrodermatitis chronica atrophicans.</data>
      <data key="d9">manifestations,symptomatology</data>
      <data key="d10">chunk-58ce513efff4e4279006c76309bbe13e</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776197741</data>
      <data key="d13" />
    </edge>
    <edge source="Acrodermatitis Chronica Atrophicans" target="Edema and Atrophic Changes">
      <data key="d7">1.0</data>
      <data key="d8">In some cases, the main presentation of acrodermatitis chronica atrophicans is edema (swelling) and atrophic changes.</data>
      <data key="d9">main presentations,symptoms</data>
      <data key="d10">chunk-58ce513efff4e4279006c76309bbe13e</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776197741</data>
      <data key="d13" />
    </edge>
    <edge source="Acrodermatitis Chronica Atrophicans" target="Knee Joint Effusion">
      <data key="d7">1.0</data>
      <data key="d8">In some cases, patients with acrodermatitis chronica atrophicans may experience knee joint effusion (fluid accumulation in the joint).</data>
      <data key="d9">manifestations,symptomatology</data>
      <data key="d10">chunk-58ce513efff4e4279006c76309bbe13e</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776197741</data>
      <data key="d13" />
    </edge>
    <edge source="Acrodermatitis Chronica Atrophicans" target="Personality Changes">
      <data key="d7">1.0</data>
      <data key="d8">In some cases, patients with acrodermatitis chronica atrophicans may experience personality changes due to central nervous system involvement.</data>
      <data key="d9">central nervous system involvement,symptoms</data>
      <data key="d10">chunk-58ce513efff4e4279006c76309bbe13e</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776197742</data>
      <data key="d13" />
    </edge>
    <edge source="Peripheral Neuropathy" target="ALS (Amyotrophic Lateral Sclerosis)">
      <data key="d7">1.0</data>
      <data key="d8">Peripheral neuropathy can be caused or exacerbated by conditions such as ALS.</data>
