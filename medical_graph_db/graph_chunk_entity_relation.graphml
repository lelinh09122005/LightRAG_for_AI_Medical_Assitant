    </node>
    <node id="Psychotic Disorder">
      <data key="d0">Psychotic Disorder</data>
      <data key="d1">mentaldisorder</data>
      <data key="d2">Psychotic disorders involve severe mental illness with distorted perception of reality.</data>
      <data key="d3">chunk-af76a19d7c4899519758f59183dd1222</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776232075</data>
