    </edge>
    <edge source="Chemicals" target="Extreme Temperatures">
      <data key="d7">1.0</data>
      <data key="d8">Extremely hot or cold temperatures can cause chemical burns by denaturing proteins in tissues.</data>
      <data key="d9">cause,type</data>
      <data key="d10">chunk-a5a80498abe28fa59b46e83f179e390b</data>
      <data key="d11">unknown_source</data>
      <data key="d12">1776207349</data>
      <data key="d13" />
    </edge>
    <edge source="Friction" target="Inhalation Injury">
      <data key="d7">1.0</data>
      <data key="d8">Rough skin or tight clothing from friction can cause further damage to the respiratory system during a burn.</data>
      <data key="d9">complication,consequence</data>
      <data key="d10">chunk-a5a80498abe28fa59b46e83f179e390b</data>
