    </node>
    <node id="Lujo Hemorrhagic Fever">
      <data key="d0">Lujo Hemorrhagic Fever</data>
      <data key="d1">disease</data>
      <data key="d2">Lujo hemorrhagic fever requires differentiation from Marburg hemorrhagic fever due to its similar clinical presentation.</data>
      <data key="d3">chunk-ef4d5f4542528f658127572749676234</data>
