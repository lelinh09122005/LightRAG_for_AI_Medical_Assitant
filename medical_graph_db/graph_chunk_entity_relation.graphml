    </node>
    <node id="Tyrosine Kinase">
      <data key="d0">Tyrosine Kinase</data>
      <data key="d1">mechanism</data>
      <data key="d2">Many of the kinase inhibitors used in treating cancer are inhibitors of tyrosine kinase.</data>
      <data key="d3">chunk-e0187e7708a45e4db3589f0e72ca7402</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776203679</data>
