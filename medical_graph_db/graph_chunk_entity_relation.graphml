      <data key="d1">disease</data>
      <data key="d2">CCHF is a viral hemorrhagic fever that shares similar signs and symptoms with Marburg hemorrhagic fever.</data>
      <data key="d3">chunk-ef4d5f4542528f658127572749676234</data>
