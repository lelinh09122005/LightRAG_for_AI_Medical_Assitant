    <node id="Tooth Abscess">
      <data key="d0">Tooth Abscess</data>
      <data key="d1">condition</data>
      <data key="d2">Patients with oral and maxillofacial infections are at increased risk of developing orbital cellulitis, such as tooth abscesses.</data>
      <data key="d3">chunk-c675cb429137f1eae8fe9eda77046b5b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776248014</data>
      <data key="d6" />
    </node>
    <node id="Otitis Media">
      <data key="d0">Otitis Media</data>
      <data key="d1">condition</data>
      <data key="d2">A history of otitis media increases the likelihood of orbital cellulitis in some patients.</data>
      <data key="d3">chunk-c675cb429137f1eae8fe9eda77046b5b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776248014</data>
      <data key="d6" />
    </node>
    <node id="Organic Brain Diseases">
      <data key="d0">Organic Brain Diseases</data>
      <data key="d1">disease</data>
      <data key="d2">Organic brain diseases are conditions that affect the brain and can lead to exercise intolerance.</data>
      <data key="d3">chunk-cbac6ca9c4de60d11284fef00668f6dc</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776248397</data>
