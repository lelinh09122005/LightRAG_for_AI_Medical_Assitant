      <data key="d0">Hantavirus Infection</data>
      <data key="d1">disease</data>
      <data key="d2">Hantavirus infection is an infectious disease to be differentiated from Marburg hemorrhagic fever due to overlapping clinical features.</data>
      <data key="d3">chunk-ef4d5f4542528f658127572749676234</data>
