    <node id="Glossitis">
      <data key="d0">Glossitis</data>
      <data key="d1">symptom</data>
      <data key="d2">Glossitis refers to inflammation of the tongue, commonly seen in patients with Plummer-Vinson syndrome.</data>
      <data key="d3">chunk-e4be7ad6187377b3faeb10739c71599a</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776202280</data>
