    </edge>
    <edge source="Osteoporosis" target="Pathological Fractures">
      <data key="d7">1.0</data>
      <data key="d8">Advanced forms of osteoporosis may lead to pathological fractures.</data>
      <data key="d9">consequence,outcome</data>
